/* pages/lostfound-detail/lostfound-detail.wxss */
page { background: #f5f5f5; }
.container { min-height: 100vh; padding-bottom: 140rpx; }

.type-badge { position: absolute; top: 30rpx; left: 30rpx; font-size: 24rpx; padding: 8rpx 20rpx; border-radius: 20rpx; color: #fff; z-index: 10; }
.type-badge.lost { background: #ef4444; }
.type-badge.found { background: #10b981; }

.title-section { background: #fff; padding: 30rpx; display: flex; justify-content: space-between; align-items: flex-start; margin-top: 80rpx; }
.item-title { font-size: 36rpx; font-weight: bold; color: #333; flex: 1; line-height: 1.4; margin-right: 20rpx; }
.item-status { font-size: 24rpx; padding: 8rpx 16rpx; border-radius: 8rpx; white-space: nowrap; }
.item-status.active { background: #fef3c7; color: #f59e0b; }
.item-status.resolved { background: #dcfce7; color: #16a34a; }

.item-image { width: 100%; height: 400rpx; }

.info-section { background: #fff; padding: 30rpx; margin-top: 20rpx; }
.info-item { display: flex; padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.info-item:last-child { border-bottom: none; }
.label { font-size: 28rpx; color: #666; width: 160rpx; }
.value { font-size: 30rpx; color: #333; flex: 1; }

.description-section { background: #fff; padding: 30rpx; margin-top: 20rpx; }
.section-title { font-size: 32rpx; font-weight: bold; color: #333; margin-bottom: 20rpx; display: block; }
.description { font-size: 30rpx; color: #666; line-height: 1.8; }

.publisher-section { background: #fff; padding: 30rpx; margin-top: 20rpx; }
.publisher-info { display: flex; align-items: center; }
.publisher-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; margin-right: 20rpx; }
.publisher-name { font-size: 30rpx; color: #333; }

.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 20rpx 30rpx; border-top: 1rpx solid #f0f0f0; }
.contact-btn { background: linear-gradient(135deg, #3b82f6, #60a5fa); color: #fff; font-size: 32rpx; font-weight: bold; padding: 24rpx 0; border-radius: 40rpx; text-align: center; }
