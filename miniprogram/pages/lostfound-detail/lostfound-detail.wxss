page { background: #f4f7fc; }
.container { min-height: 100vh; padding: 24rpx 24rpx 160rpx; box-sizing: border-box; }
.head { display: flex; justify-content: space-between; align-items: center; }
.type { font-size: 26rpx; color: #1d4ed8; background: #dbeafe; padding: 6rpx 14rpx; border-radius: 999rpx; }
.status { font-size: 24rpx; color: #334155; }
.title { display: block; margin-top: 14rpx; font-size: 36rpx; color: #0f172a; font-weight: 700; line-height: 1.4; }
.cover { width: 100%; height: 380rpx; border-radius: 18rpx; margin-top: 16rpx; background: #e2e8f0; }
.block { margin-top: 16rpx; background: #fff; border-radius: 16rpx; padding: 20rpx; }
.row { padding: 10rpx 0; }
.k { display: block; font-size: 22rpx; color: #64748b; }
.v { display: block; margin-top: 6rpx; font-size: 28rpx; color: #0f172a; line-height: 1.5; }
.claim-title { display: block; font-size: 30rpx; color: #0f172a; font-weight: 600; margin-bottom: 12rpx; }
.claim-input { width: 100%; min-height: 140rpx; background: #f8fafc; border-radius: 12rpx; padding: 16rpx; box-sizing: border-box; font-size: 26rpx; }
.claim-btn { margin-top: 14rpx; text-align: center; border-radius: 12rpx; background: #059669; color: #fff; padding: 18rpx 0; font-size: 28rpx; }
.claim-tip { display: block; margin-top: 10rpx; color: #64748b; font-size: 22rpx; }
.bottom-bar { position: fixed; left: 0; right: 0; bottom: 0; padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom)); background: #fff; border-top: 1rpx solid #e2e8f0; }
.contact-btn { text-align: center; background: #1d4ed8; color: #fff; border-radius: 12rpx; padding: 20rpx 0; font-size: 28rpx; }
