<!-- pages/lostfound-detail/lostfound-detail.wxml -->
<view class="container">
  <view class="type-badge {{item.type}}">{{item.type === 'lost' ? '寻物启事' : '招领启事'}}</view>
  
  <view class="title-section">
    <text class="item-title">{{item.title}}</text>
    <text class="item-status {{item.status === '寻找中' || item.status === '待认领' ? 'active' : 'resolved'}}">{{item.status}}</text>
  </view>

  <image wx:if="{{item.image}}" class="item-image" src="{{item.image}}" mode="aspectFill"/>

  <view class="info-section">
    <view class="info-item">
      <text class="label">{{item.type === 'lost' ? '丢失地点' : '拾获地点'}}</text>
      <text class="value">{{item.location}}</text>
    </view>
    <view class="info-item">
      <text class="label">{{item.type === 'lost' ? '丢失时间' : '拾获时间'}}</text>
      <text class="value">{{item.time}}</text>
    </view>
  </view>

  <view class="description-section">
    <text class="section-title">详细描述</text>
    <text class="description">{{item.description}}</text>
  </view>

  <view class="publisher-section">
    <text class="section-title">发布者</text>
    <view class="publisher-info">
      <image class="publisher-avatar" src="{{item.publisher.avatar}}" mode="aspectFill"/>
      <text class="publisher-name">{{item.publisher.nickname}}</text>
    </view>
  </view>

  <view class="bottom-bar">
    <view class="contact-btn" bindtap="onContactTap">
      <text>联系发布者</text>
    </view>
  </view>
</view>
