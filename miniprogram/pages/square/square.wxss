/* pages/square/square.wxss - 柔和蓝白主题 · 校园广场页 */

/* ===================== 页面基础 ===================== */
.square-page {
  min-height: 100vh;
  background: #f0f6ff;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===================== 顶部搜索栏 ===================== */
.top-search {
  background: linear-gradient(160deg, #5b9cf6 0%, #7dd3fc 60%, #bae6fd 100%);
  padding: 20rpx 28rpx 36rpx;
  position: sticky;
  top: 0;
  z-index: 200;
  box-shadow: 0 4rpx 20rpx rgba(91, 156, 246, 0.2);
  left: 0;
  right: 0;
}

.square-search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.square-search-row .capsule-search {
  flex: 1;
  min-width: 0;
}

/* ===================== 轮播图区域 ===================== */
.banner-section {
  padding: 28rpx 28rpx 0;
  background: linear-gradient(160deg, #5b9cf6 0%, #7dd3fc 60%, #bae6fd 100%);
}

.banner-swiper {
  height: 300rpx;
  border-radius: 24rpx;
  overflow: visible;
}

.banner-item {
  height: 300rpx;
  border-radius: 24rpx;
  overflow: hidden;
  transition: transform 0.3s;
  box-shadow: 0 8rpx 32rpx rgba(91, 156, 246, 0.2);
  position: relative;
}

.banner-item.active {
  transform: scale(1.02);
}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60%;
  background: linear-gradient(to top, rgba(10, 20, 40, 0.65), transparent);
}

.banner-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 28rpx;
}

.banner-tag {
  display: inline-flex;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 100rpx;
  padding: 6rpx 20rpx;
  margin-bottom: 12rpx;
}

.banner-tag-text {
  font-size: 22rpx;
  color: #5b9cf6;
  font-weight: 600;
}

.banner-title {
  font-size: 32rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1.4;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

/* ===================== 快捷入口 ===================== */
.quick-entry-section {
  padding: 0 28rpx;
  margin-top: -20rpx;
  position: relative;
  z-index: 50;
}

.quick-grid {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(91, 156, 246, 0.1);
  padding: 28rpx 8rpx 20rpx;
  display: flex;
  justify-content: space-around;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  padding: 8rpx 0;
}

.quick-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s, box-shadow 0.2s;
  box-sizing: border-box;
  padding: 18rpx;
}

.quick-icon--notice {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
}

.quick-icon--college {
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
}

.quick-icon--market {
  background: linear-gradient(135deg, #dcfce7, #bbf7d0);
}

.quick-icon--lost {
  background: linear-gradient(135deg, #fae8ff, #f5d0fe);
}

.quick-icon:active {
  transform: scale(0.93);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.quick-icon-img {
  width: 52rpx;
  height: 52rpx;
  display: block;
  flex-shrink: 0;
}

.quick-name {
  font-size: 24rpx;
  color: #4a6fa5;
  font-weight: 500;
}

/* ===================== 通知滚动栏 ===================== */
.notice-scroll-bar {
  margin: 24rpx 28rpx 0;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(91, 156, 246, 0.08);
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  overflow: hidden;
}

.notice-label {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #eef6ff;
  border-radius: 12rpx;
  padding: 10rpx 16rpx;
  flex-shrink: 0;
}

.college-notice-bar {
  margin-top: 16rpx;
}

.college-label {
  background: #eff6ff;
}

.notice-label-icon {
  font-size: 28rpx;
}

.notice-label-text {
  font-size: 20rpx;
  color: #5b9cf6;
  font-weight: 600;
  margin-top: 2rpx;
}

.notice-swiper {
  flex: 1;
  height: 80rpx;
  overflow: hidden;
}

.notice-swipe-item {
  font-size: 26rpx;
  color: #4a6fa5;
  line-height: 80rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notice-more {
  font-size: 24rpx;
  color: #9ca3af;
  flex-shrink: 0;
}

/* ===================== 区域标题 ===================== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 28rpx 20rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-title-bar {
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(180deg, #5b9cf6, #38bdf8);
  border-radius: 4rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1e3a5f;
  letter-spacing: 1rpx;
}

.section-right {
  display: flex;
  align-items: center;
}

.post-count {
  font-size: 24rpx;
  color: #9ca3af;
}

/* ===================== 帖子卡片列表 ===================== */
.post-list {
  padding: 0 28rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.post-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 156, 246, 0.08);
  overflow: hidden;
  transition: box-shadow 0.2s;
}

.post-card:active {
  box-shadow: 0 2rpx 12rpx rgba(91, 156, 246, 0.06);
}

/* 卡片头部 */
.post-header {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx 0;
}

.user-avatar-wrap {
  position: relative;
  margin-right: 16rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #e8f2ff;
}

.avatar-ring {
  position: absolute;
  inset: -4rpx;
  border-radius: 50%;
  border: 2rpx solid #93c5fd;
  opacity: 0;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e3a5f;
  margin-bottom: 4rpx;
}

.user-time {
  font-size: 22rpx;
  color: #9ca3af;
}

.post-tag {
  background: #fff7ed;
  border-radius: 100rpx;
  padding: 6rpx 16rpx;
  border: 1rpx solid #fed7aa;
}

.post-tag-text {
  font-size: 22rpx;
  color: #ea580c;
  font-weight: 600;
}

/* 卡片内容 */
.post-body {
  padding: 20rpx 24rpx;
}

.post-title-line {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1e3a5f;
  line-height: 1.45;
  margin-bottom: 12rpx;
}

.post-content {
  font-size: 30rpx;
  color: #374151;
  line-height: 1.7;
  margin-bottom: 20rpx;
  display: block;
}

.post-images {
  margin-top: 4rpx;
}

.post-img-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.post-img-wrap.single .post-img {
  width: 380rpx;
  height: 300rpx;
  border-radius: 16rpx;
}

.post-img-wrap:not(.single) .post-img {
  width: 218rpx;
  height: 218rpx;
  border-radius: 12rpx;
}

.post-img {
  display: block;
  background: #e5e7eb;
}

/* 卡片底部互动栏 */
.post-footer {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx 20rpx;
  border-top: 1rpx solid #f3f4f6;
  gap: 8rpx;
}

.action-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 10rpx 0;
  background: #f8fafc;
  border-radius: 100rpx;
  margin-right: 8rpx;
  transition: background 0.2s;
}

.action-item:last-child {
  margin-right: 0;
}

.action-item:active {
  background: #eef6ff;
}

.action-icon {
  font-size: 30rpx;
}

.action-icon.liked {
  animation: heartPop 0.3s ease-out;
}

@keyframes heartPop {
  0% { transform: scale(1); }
  50% { transform: scale(1.4); }
  100% { transform: scale(1); }
}

.action-count {
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 500;
}

/* 底部占位 */
.bottom-space {
  height: 140rpx;
}

/* ===================== 动态筛选标签 ===================== */
.filter-tabs-wrap {
  padding: 0 28rpx;
  margin-bottom: 8rpx;
}

.filter-tabs-scroll {
  white-space: nowrap;
}

.filter-tabs {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 0 8rpx;
}

.filter-tab {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: 100rpx;
  border: 2rpx solid #e5e7eb;
  flex-shrink: 0;
  transition: all 0.2s;
}

.filter-tab.active {
  background: linear-gradient(135deg, #5b9cf6, #74aef8);
  border-color: #5b9cf6;
  box-shadow: 0 4rpx 16rpx rgba(91, 156, 246, 0.25);
}

.filter-tab-text {
  font-size: 26rpx;
  color: #6b7280;
  font-weight: 500;
  white-space: nowrap;
}

.filter-tab.active .filter-tab-text {
  color: #fff;
  font-weight: 600;
}

/* ===================== 右下角固定发布按钮 ===================== */
.fixed-publish-btn {
  position: fixed;
  right: 32rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  z-index: 500;
}

.publish-btn-inner {
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(145deg, #5b9cf6, #3b82f6);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 28rpx rgba(59, 130, 246, 0.45);
  transition: transform 0.2s, box-shadow 0.2s;
}

.publish-btn-inner:active {
  transform: scale(0.93);
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.3);
}

.publish-btn-icon {
  font-size: 40rpx;
  margin-bottom: 2rpx;
}

.publish-btn-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1;
}
