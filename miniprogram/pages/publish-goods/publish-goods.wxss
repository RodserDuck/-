/* pages/publish-goods/publish-goods.wxss */
page { background: #f0f6ff; }
.container {
  min-height: 100vh;
  padding-bottom: 0;
  box-sizing: border-box;
}

.image-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-label {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 20rpx;
}

.required { color: #ef4444; }

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.uploaded-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: #ef4444;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
}

.add-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.add-icon { font-size: 60rpx; color: #999; }
.add-text { font-size: 24rpx; color: #999; margin-top: 10rpx; }

.form-section {
  background: #fff;
  margin-bottom: 20rpx;
}

.form-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child { border-bottom: none; }

.form-row { display: flex; }

.form-item.half {
  flex: 1;
  border-right: 1rpx solid #f5f5f5;
}

.form-item.half:last-child { border-right: none; }

.label {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

input { font-size: 30rpx; color: #333; }

.price-input { display: flex; align-items: center; }

.currency {
  font-size: 32rpx;
  color: #666;
  margin-right: 12rpx;
}

.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  color: #333;
}

.arrow { color: #999; font-size: 28rpx; }

.description-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.description-input {
  width: 100%;
  min-height: 200rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #333;
}

/* 底部占位，避免内容被固定底栏遮挡 */
.bottom-space {
  height: 180rpx;
}

.bottom-publish-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  background: #fff;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(91, 156, 246, 0.1);
}

.publish-btn-full {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #5b9cf6, #4891e8);
  border-radius: 48rpx;
  box-shadow: 0 8rpx 28rpx rgba(59, 130, 246, 0.35);
}

.publish-btn-full:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.25);
}

.publish-btn-full.disabled {
  background: #d1d5db;
  box-shadow: none;
}

.publish-btn-full .btn-icon {
  font-size: 36rpx;
}

.publish-btn-full .btn-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 700;
}

.publish-btn-full.disabled .btn-text {
  color: #fff;
}
