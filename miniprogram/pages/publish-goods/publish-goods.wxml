<!-- pages/publish-goods/publish-goods.wxml：系统导航栏 + 底部发布（与发布帖子一致） -->
<view class="container">
  <view class="image-section">
    <text class="section-label">商品图片 <text class="required">*</text></text>
    <view class="image-grid">
      <view class="image-item" wx:for="{{images}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" class="uploaded-image"/>
        <view class="delete-btn" bindtap="onDeleteImage" data-index="{{index}}">
          <text>×</text>
        </view>
      </view>
      <view class="add-btn" wx:if="{{images.length < maxImages}}" bindtap="onChooseImage">
        <text class="add-icon">+</text>
        <text class="add-text">{{images.length}}/{{maxImages}}</text>
      </view>
    </view>
  </view>

  <view class="form-section">
    <view class="form-item">
      <text class="label">标题 <text class="required">*</text></text>
      <input type="text" placeholder="请输入商品标题" value="{{title}}" bindinput="onTitleInput"/>
    </view>
    
    <view class="form-row">
      <view class="form-item half">
        <text class="label">售价 <text class="required">*</text></text>
        <view class="price-input">
          <text class="currency">¥</text>
          <input type="digit" placeholder="0.00" value="{{price}}" bindinput="onPriceInput"/>
        </view>
      </view>
      <view class="form-item half">
        <text class="label">原价</text>
        <view class="price-input">
          <text class="currency">¥</text>
          <input type="digit" placeholder="0.00" value="{{originalPrice}}" bindinput="onOriginalPriceInput"/>
        </view>
      </view>
    </view>

    <view class="form-row">
      <view class="form-item half" bindtap="onCategoryTap">
        <text class="label">分类 <text class="required">*</text></text>
        <view class="picker-value">
          <text>{{categoryName}}</text>
          <text class="arrow">></text>
        </view>
      </view>
      <view class="form-item half" bindtap="onConditionTap">
        <text class="label">成色</text>
        <view class="picker-value">
          <text>{{conditionName}}</text>
          <text class="arrow">></text>
        </view>
      </view>
    </view>

    <view class="form-item">
      <text class="label">交易地点</text>
      <input type="text" placeholder="如：西区宿舍" value="{{location}}" bindinput="onLocationInput"/>
    </view>
  </view>

  <view class="description-section">
    <text class="section-label">商品描述</text>
    <textarea 
      class="description-input"
      placeholder="描述商品的品牌型号、入手渠道等..."
      value="{{description}}"
      bindinput="onDescriptionInput"
      maxlength="500"
    />
  </view>

  <view class="bottom-space"></view>

  <view class="bottom-publish-bar">
    <view
      class="publish-btn-full {{isSubmitting ? 'disabled' : ''}}"
      bindtap="onPublish"
    >
      <text class="btn-icon">📦</text>
      <text class="btn-text">发布闲置</text>
    </view>
  </view>
</view>
