/* pages/my-posts/my-posts.wxss */
page { background: #f0f6ff; }
.page { min-height: 100vh; padding: 24rpx 28rpx; }

.post-list { display: flex; flex-direction: column; gap: 24rpx; }

.post-card {
  background: #fff; border-radius: 24rpx;
  padding: 28rpx; box-shadow: 0 4rpx 20rpx rgba(91,156,246,0.08);
  display: flex; flex-direction: column; gap: 16rpx;
}

.post-header { display: flex; align-items: center; gap: 16rpx; }
.post-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; border: 4rpx solid #e8f2ff; flex-shrink: 0; }
.post-meta { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.post-nickname { font-size: 28rpx; font-weight: 600; color: #1e3a5f; }
.post-time { font-size: 22rpx; color: #9ca3af; }
.post-delete { padding: 8rpx; flex-shrink: 0; }
.delete-icon { font-size: 32rpx; opacity: 0.5; }

.post-title-my { font-size: 30rpx; font-weight: 700; color: #1e3a5f; line-height: 1.5; }

.post-content { font-size: 28rpx; color: #374151; line-height: 1.8; }

.post-images { display: flex; flex-wrap: wrap; gap: 8rpx; }
.post-image { width: 200rpx; height: 200rpx; border-radius: 12rpx; }

.post-footer { display: flex; gap: 32rpx; padding-top: 12rpx; border-top: 1rpx solid #f3f4f6; }
.post-stat { display: flex; align-items: center; gap: 6rpx; }
.stat-icon { font-size: 24rpx; }
.stat-num { font-size: 24rpx; color: #9ca3af; }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 24rpx; gap: 16rpx; }
.empty-emoji { font-size: 96rpx; opacity: 0.3; }
.empty-title { font-size: 32rpx; font-weight: 600; color: #374151; }
.empty-sub { font-size: 26rpx; color: #9ca3af; }
.empty-btn { background: linear-gradient(135deg, #5b9cf6, #4891e8); border-radius: 100rpx; padding: 20rpx 48rpx; margin-top: 8rpx; box-shadow: 0 8rpx 24rpx rgba(91,156,246,0.3); }
.empty-btn-text { font-size: 28rpx; color: #fff; font-weight: 700; }

.loading-state { display: flex; justify-content: center; padding: 60rpx; }
.loading-text { font-size: 28rpx; color: #9ca3af; }
