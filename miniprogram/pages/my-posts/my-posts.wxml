<!-- pages/my-posts/my-posts.wxml -->
<view class="page">
  <view class="post-list" wx:if="{{!empty}}">
    <view
      class="post-card"
      wx:for="{{posts}}"
      wx:key="id"
      bindtap="onPostTap"
      data-id="{{item.id}}"
    >
      <view class="post-header">
        <image class="post-avatar" src="{{item.avatar}}" mode="aspectFill"/>
        <view class="post-meta">
          <text class="post-nickname">{{item.nickname}}</text>
          <text class="post-time">{{item.time}}</text>
        </view>
        <view class="post-delete" catchtap="onDeleteTap" data-id="{{item.id}}">
          <text class="delete-icon">🗑️</text>
        </view>
      </view>
      <text class="post-title-my" wx:if="{{item.title}}">{{item.title}}</text>
      <text class="post-content" wx:if="{{item.snippet}}">{{item.snippet}}</text>
      <view class="post-images" wx:if="{{item.images.length > 0}}">
        <image
          class="post-image"
          wx:for="{{item.images}}"
          wx:for-item="img"
          wx:key="*this"
          src="{{img}}"
          mode="aspectFill"
          data-images="{{item.images}}"
          data-src="{{img}}"
          bindtap="onPreviewImage"
        />
      </view>
      <view class="post-footer">
        <view class="post-stat">
          <text class="stat-icon">👁</text>
          <text class="stat-num">{{item.viewCount || 0}}</text>
        </view>
        <view class="post-stat">
          <text class="stat-icon">❤️</text>
          <text class="stat-num">{{item.likes}}</text>
        </view>
        <view class="post-stat">
          <text class="stat-icon">💬</text>
          <text class="stat-num">{{item.comments}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{empty && !loading}}">
    <text class="empty-emoji">📝</text>
    <text class="empty-title">还没有发布帖子</text>
    <text class="empty-sub">分享你的校园生活吧</text>
    <view class="empty-btn" bindtap="onPublishTap">
      <text class="empty-btn-text">发布帖子</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>
</view>
