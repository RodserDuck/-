/* pages/my-clubs/my-clubs.wxss */
page { background: #f0f6ff; }
.page { min-height: 100vh; padding: 24rpx 28rpx; }

.club-list { display: flex; flex-direction: column; gap: 20rpx; }

.club-card {
  background: #fff; border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(91,156,246,0.08); overflow: hidden;
}

.club-main { display: flex; align-items: center; gap: 16rpx; padding: 24rpx; }
.club-avatar { width: 96rpx; height: 96rpx; border-radius: 20rpx; border: 4rpx solid #e8f2ff; flex-shrink: 0; }
.club-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 6rpx; }
.club-name-row { display: flex; align-items: center; gap: 12rpx; }
.club-name { font-size: 30rpx; font-weight: 700; color: #1e3a5f; }
.club-role-badge { background: linear-gradient(135deg, #5b9cf6, #4891e8); border-radius: 100rpx; padding: 4rpx 14rpx; }
.role-text { font-size: 20rpx; color: #fff; font-weight: 600; }
.club-desc { font-size: 24rpx; color: #9ca3af; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.club-member-count { font-size: 22rpx; color: #9ca3af; }
.club-arrow { font-size: 40rpx; color: #d1d5db; font-weight: 300; flex-shrink: 0; }

.club-actions { display: flex; border-top: 1rpx solid #f3f4f6; }
.club-btn { flex: 1; display: flex; align-items: center; justify-content: center; padding: 20rpx; font-size: 26rpx; font-weight: 500; border-right: 1rpx solid #f3f4f6; }
.club-btn:last-child { border-right: none; }
.club-btn.danger { color: #ef4444; background: #fef2f2; }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 24rpx; gap: 16rpx; }
.empty-emoji { font-size: 96rpx; opacity: 0.3; }
.empty-title { font-size: 32rpx; font-weight: 600; color: #374151; }
.empty-sub { font-size: 26rpx; color: #9ca3af; }

.loading-state { display: flex; justify-content: center; padding: 60rpx; }
.loading-text { font-size: 28rpx; color: #9ca3af; }
