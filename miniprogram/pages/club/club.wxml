<!-- pages/club/club.wxml -->
<view class="club-page">

  <!-- 顶部区域 -->
  <view class="top-area">
    <view class="top-bar">
      <view class="page-title">社团广场</view>
      <view class="top-actions">
        <view class="action-icon-btn" bindtap="onNotifyTap">
          <text class="icon-text">🔔</text>
          <view class="red-dot" wx:if="{{hasNotify}}"></view>
        </view>
      </view>
    </view>
    <view class="search-row">
      <view class="search-bar">
        <text class="search-icon-text">🔍</text>
        <input
          class="search-input"
          type="text"
          placeholder="搜索社团或活动"
          placeholder-class="search-placeholder"
          bindconfirm="onSearch"
        />
      </view>
    </view>
  </view>

  <!-- Tab标签栏 -->
  <view class="tab-bar">
    <view
      class="tab-item {{currentTab === 0 ? 'active' : ''}}"
      bindtap="onTabChange"
      data-index="0"
    >
      <text class="tab-text">社团</text>
      <view class="tab-indicator" wx:if="{{currentTab === 0}}"></view>
    </view>
    <view
      class="tab-item {{currentTab === 1 ? 'active' : ''}}"
      bindtap="onTabChange"
      data-index="1"
    >
      <text class="tab-text">活动</text>
      <view class="tab-indicator" wx:if="{{currentTab === 1}}"></view>
    </view>
    <view
      class="tab-item {{currentTab === 2 ? 'active' : ''}}"
      bindtap="onTabChange"
      data-index="2"
    >
      <text class="tab-text">我的</text>
      <view class="tab-indicator" wx:if="{{currentTab === 2}}"></view>
    </view>
  </view>

  <!-- ==================== 全部社团 ==================== -->
  <view class="tab-content" wx:if="{{currentTab === 0}}">
    <!-- 分类横向滚动 -->
    <scroll-view class="category-scroll" scroll-x enhanced show-scrollbar="false">
      <view class="category-list">
        <view
          class="category-chip {{selectedCategory === item.id ? 'active' : ''}}"
          wx:for="{{categories}}"
          wx:key="id"
          bindtap="onCategoryTap"
          data-id="{{item.id}}"
        >
          <text class="chip-text">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>

    <!-- 社团卡片列表 -->
    <view class="club-list">
      <view
        class="club-card {{club._animClass}}"
        wx:for="{{filteredClubs}}"
        wx:key="id"
        bindtap="onClubTap"
        data-id="{{item.id}}"
      >
        <!-- 左侧图标区 -->
        <view class="club-avatar-zone">
          <view class="club-avatar" style="background: {{item.gradient}}">
            <text class="club-emoji">{{item.icon}}</text>
          </view>
        </view>

        <!-- 中间内容区 -->
        <view class="club-info-zone">
          <view class="club-name-row">
            <text class="club-name">{{item.name}}</text>
            <view class="club-category-badge">
              <text class="badge-dot" style="background: {{item.badgeColor}}"></text>
              <text class="badge-text">{{item.category}}</text>
            </view>
          </view>
          <text class="club-desc" wx:if="{{item.description}}">{{item.description}}</text>
          <view class="club-meta-row">
            <view class="meta-pill">
              <text class="pill-icon">👥</text>
              <text class="pill-num">{{item.members}}</text>
              <text class="pill-label">人</text>
            </view>
            <view class="meta-pill hot-pill">
              <text class="pill-icon">🔥</text>
              <text class="pill-num">{{item.hot}}</text>
            </view>
          </view>
        </view>

        <!-- 右侧操作区 -->
        <view class="club-action-zone">
          <view
            class="join-btn {{item.followed ? 'joined' : ''}}"
            bindtap="onFollowClub"
            data-id="{{item.id}}"
            catchtap="onFollowClub"
          >
            <text class="join-btn-text">{{item.followed ? '已加入' : '加入'}}</text>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{filteredClubs.length === 0}}">
        <text class="empty-icon">🏘️</text>
        <text class="empty-title">暂无社团</text>
        <text class="empty-sub">换个分类试试吧</text>
      </view>
    </view>
  </view>

  <!-- ==================== 社团活动 ==================== -->
  <view class="tab-content" wx:if="{{currentTab === 1}}">
    <!-- 活动筛选横滑 -->
    <scroll-view class="activity-filter-scroll" scroll-x enhanced show-scrollbar="false">
      <view class="activity-filter-list">
        <view
          class="act-filter-chip {{selectedActFilter === 0 ? 'active' : ''}}"
          bindtap="onActFilterTap"
          data-id="0"
        >
          <text>全部</text>
        </view>
        <view
          class="act-filter-chip {{selectedActFilter === 1 ? 'active' : ''}}"
          bindtap="onActFilterTap"
          data-id="1"
        >
          <text>报名中</text>
        </view>
        <view
          class="act-filter-chip {{selectedActFilter === 2 ? 'active' : ''}}"
          bindtap="onActFilterTap"
          data-id="2"
        >
          <text>进行中</text>
        </view>
        <view
          class="act-filter-chip {{selectedActFilter === 3 ? 'active' : ''}}"
          bindtap="onActFilterTap"
          data-id="3"
        >
          <text>往期回顾</text>
        </view>
      </view>
    </scroll-view>

    <!-- 活动列表 -->
    <view class="activity-list">
      <view
        class="activity-card {{act._animClass}}"
        wx:for="{{filteredActivities}}"
        wx:key="id"
        bindtap="onActivityTap"
        data-id="{{item.id}}"
      >
        <!-- 左侧图片区 -->
        <view class="act-image-wrap">
          <image class="act-image" src="{{item.image}}" mode="aspectFill" lazy-load />
          <view class="act-status-strip {{item.statusClass}}">
            <text class="act-status-text">{{item.status}}</text>
          </view>
        </view>

        <!-- 右侧信息区 -->
        <view class="act-info-wrap">
          <text class="act-title">{{item.title}}</text>
          <view class="act-org">
            <text class="act-org-icon">🏘️</text>
            <text class="act-org-name">{{item.club}}</text>
          </view>
          <view class="act-detail-row">
            <text class="act-detail-icon">📅</text>
            <text class="act-detail-text">{{item.time}}</text>
          </view>
          <view class="act-detail-row">
            <text class="act-detail-icon">📍</text>
            <text class="act-detail-text">{{item.location}}</text>
          </view>

          <view class="act-footer">
            <view class="act-hot-wrap">
              <text class="act-hot-icon">🔥</text>
              <text class="act-hot-num">{{item.hot}}</text>
            </view>
            <view
              class="act-sign-btn {{item.statusClass === 'closed' ? 'disabled' : ''}}"
              bindtap="onJoinActivity"
              data-id="{{item.id}}"
              catchtap="onJoinActivity"
            >
              <text class="sign-btn-text">{{item.statusClass === 'closed' ? '已结束' : '立即报名'}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{filteredActivities.length === 0}}">
        <text class="empty-icon">🎉</text>
        <text class="empty-title">暂无活动</text>
        <text class="empty-sub">关注社团获取最新活动</text>
      </view>
    </view>
  </view>

  <!-- ==================== 我的社团 ==================== -->
  <view class="tab-content" wx:if="{{currentTab === 2}}">

    <!-- 头像信息卡片 -->
    <view class="profile-card">
      <view class="profile-left">
        <view class="profile-avatar">
          <image class="profile-img" src="{{userInfo.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill" />
        </view>
        <view class="profile-info">
          <text class="profile-name">{{userInfo.nickName || '校园用户'}}</text>
          <text class="profile-sub">共加入 {{myClubs.length}} 个社团</text>
        </view>
      </view>
      <view class="profile-right">
        <view class="stat-block">
          <text class="stat-num">{{myActivities.length}}</text>
          <text class="stat-label">报名活动</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-block">
          <text class="stat-num">{{myClubs.length}}</text>
          <text class="stat-label">加入社团</text>
        </view>
      </view>
    </view>

    <!-- 我加入的社团 -->
    <view class="section-block" wx:if="{{myClubs.length > 0}}">
      <view class="section-header">
        <text class="section-title">我加入的社团</text>
        <text class="section-count">{{myClubs.length}} 个</text>
      </view>
      <view class="my-club-cards">
        <view
          class="my-club-chip"
          wx:for="{{myClubs}}"
          wx:key="id"
          bindtap="onClubTap"
          data-id="{{item.id}}"
        >
          <view class="chip-avatar" style="background: {{item.gradient}}">
            <text class="chip-emoji">{{item.icon}}</text>
          </view>
          <text class="chip-name">{{item.name}}</text>
          <text class="chip-role {{item.roleClass}}">{{item.role}}</text>
        </view>
      </view>
    </view>

    <!-- 我报名的活动 -->
    <view class="section-block">
      <view class="section-header">
        <text class="section-title">我报名的活动</text>
        <text class="section-more" bindtap="onTabChange" data-index="1">全部活动 ›</text>
      </view>
      <view class="empty-state-sm" wx:if="{{myActivities.length === 0}}">
        <text class="empty-sm-icon">📋</text>
        <text class="empty-sm-text">还没有报名的活动</text>
        <view class="empty-sm-btn" bindtap="onTabChange" data-index="1">
          <text class="empty-sm-btn-text">去报名</text>
        </view>
      </view>
      <view class="my-activity-list" wx:else>
        <view
          class="my-act-item"
          wx:for="{{myActivities}}"
          wx:key="id"
          bindtap="onActivityTap"
          data-id="{{item.id}}"
        >
          <view class="my-act-left">
            <text class="my-act-title">{{item.title}}</text>
            <text class="my-act-meta">📅 {{item.time}}</text>
          </view>
          <view class="my-act-status {{item.statusClass}}">
            <text class="my-act-status-text">{{item.status}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-space"></view>
</view>
