/* pages/college-notice-detail/college-notice-detail.wxss - 紫蓝渐变主题 */
page { background: #f0f6ff; }
.notice-page { min-height: 100vh; padding-bottom: env(safe-area-inset-bottom); }

/* 顶部导航 */
.nav-bar {
  display: flex; justify-content: space-between; align-items: center;
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  position: sticky; top: 0; z-index: 100;
}
.nav-back { width: 60rpx; height: 60rpx; display: flex; align-items: center; justify-content: center; }
.back-icon { font-size: 52rpx; color: #fff; font-weight: bold; line-height: 1; }
.nav-title { font-size: 34rpx; font-weight: 700; color: #fff; flex: 1; text-align: center; }
.nav-placeholder { width: 60rpx; }

/* 内容区域 */
.notice-content { padding: 32rpx 28rpx; }

/* 标签+时间 */
.notice-meta { display: flex; align-items: center; gap: 16rpx; margin-bottom: 20rpx; }
.type-tag {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 100rpx;
  padding: 8rpx 22rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}
.type-tag-text { font-size: 22rpx; color: #fff; font-weight: 600; }
.notice-time { font-size: 24rpx; color: #9ca3af; }

/* 标题 */
.notice-title-wrap {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 36rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.08);
}
.notice-title { font-size: 40rpx; font-weight: 700; color: #1e3a5f; line-height: 1.5; display: block; }

/* 分隔线 */
.divider { height: 1rpx; background: #e8edff; margin-bottom: 20rpx; }

/* 正文 */
.notice-body {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx 36rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.08);
}
.notice-text { font-size: 32rpx; color: #374151; line-height: 1.9; display: block; }

/* 图片 */
.notice-images {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.08);
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.notice-img { width: 100%; border-radius: 12rpx; display: block; background: #f3f4f6; }

/* 页脚 */
.notice-footer { text-align: center; padding: 16rpx 0; }
.view-count { font-size: 24rpx; color: #c0b8e8; }

/* 加载 */
.loading-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.loading-dots { display: flex; gap: 12rpx; margin-bottom: 20rpx; }
.dot { width: 16rpx; height: 16rpx; background: #667eea; border-radius: 50%; animation: bounce 1.2s ease-in-out infinite; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}
.loading-text { font-size: 28rpx; color: #9ca3af; }
