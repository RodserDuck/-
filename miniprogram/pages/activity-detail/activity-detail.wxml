<!-- pages/activity-detail/activity-detail.wxml -->
<view class="container">
  <image class="activity-banner" src="{{activity.image}}" mode="aspectFill"/>

  <view class="info-section">
    <text class="activity-title">{{activity.title}}</text>
    <text class="activity-club">{{activity.club}}</text>
    
    <view class="info-list">
      <view class="info-item">
        <text class="icon">📅</text>
        <text class="label">活动时间：</text>
        <text class="value">{{activity.time}}</text>
      </view>
      <view class="info-item">
        <text class="icon">📍</text>
        <text class="label">活动地点：</text>
        <text class="value">{{activity.location}}</text>
      </view>
      <view class="info-item">
        <text class="icon">👥</text>
        <text class="label">报名人数：</text>
        <text class="value">{{activity.participants}}/{{activity.maxParticipants}}人</text>
      </view>
    </view>

    <view class="status-badge {{activity.status === '报名中' ? 'open' : 'closed'}}">{{activity.status}}</view>
  </view>

  <view class="section">
    <view class="section-title">活动详情</view>
    <text class="content-text">{{activity.description}}</text>
  </view>

  <view class="section">
    <view class="section-title">参与要求</view>
    <text class="content-text" style="white-space: pre-line;">{{activity.requirements}}</text>
  </view>

  <view class="bottom-bar">
    <view class="join-btn {{activity.isJoined ? 'joined' : ''}} {{activity.status !== '报名中' ? 'disabled' : ''}}" bindtap="onJoinActivity">
      <text wx:if="{{activity.isJoined}}">已报名</text>
      <text wx:elif="{{activity.status !== '报名中'}}">{{activity.status}}</text>
      <text wx:else>立即报名</text>
    </view>
  </view>
</view>
