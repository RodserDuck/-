/* pages/activity-detail/activity-detail.wxss */
page { background: #f0f6ff; }
.detail-page { min-height: 100vh; display: flex; flex-direction: column; }

.nav-bar {
  display: flex; justify-content: space-between; align-items: center;
  background: linear-gradient(135deg, #5b9cf6 0%, #7dd3fc 100%);
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  position: sticky; top: 0; z-index: 200;
}
.nav-back { width: 60rpx; height: 60rpx; display: flex; align-items: center; justify-content: center; }
.back-icon { font-size: 52rpx; color: #fff; font-weight: bold; line-height: 1; }
.nav-title { font-size: 34rpx; font-weight: 700; color: #fff; flex: 1; text-align: center; }
.nav-placeholder { width: 60rpx; }

.main-scroll { flex: 1; padding-bottom: 140rpx; }

.cover-section { position: relative; }
.cover-image { width: 100%; height: 400rpx; display: block; }
.cover-overlay {
  position: absolute; top: 0; right: 0; padding: 20rpx;
}
.status-badge {
  border-radius: 100rpx; padding: 10rpx 28rpx;
  font-size: 24rpx; font-weight: 700; color: #fff;
}
.status-badge.open { background: linear-gradient(135deg, #5b9cf6, #38bdf8); }
.status-badge.ongoing { background: linear-gradient(135deg, #34d399, #10b981); }
.status-badge.closed { background: rgba(0,0,0,0.45); }

.info-card {
  background: #fff; padding: 32rpx; margin: 20rpx; border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 156, 246, 0.08);
}
.act-title {
  font-size: 38rpx; font-weight: 700; color: #1e3a5f;
  line-height: 1.4; display: block; margin-bottom: 16rpx;
}
.org-row { display: flex; align-items: center; gap: 8rpx; margin-bottom: 24rpx; }
.org-icon { font-size: 28rpx; }
.org-name { font-size: 28rpx; color: #5b9cf6; font-weight: 600; }

.info-grid { display: flex; flex-direction: column; gap: 20rpx; }
.info-cell { display: flex; align-items: flex-start; gap: 16rpx; }
.cell-icon { font-size: 36rpx; flex-shrink: 0; margin-top: 4rpx; }
.cell-content { display: flex; flex-direction: column; gap: 4rpx; }
.cell-label { font-size: 24rpx; color: #9ca3af; }
.cell-value { font-size: 28rpx; color: #374151; font-weight: 500; }

.section-card {
  background: #fff; padding: 28rpx 32rpx; margin: 0 20rpx 20rpx;
  border-radius: 24rpx; box-shadow: 0 4rpx 20rpx rgba(91, 156, 246, 0.08);
}
.section-title-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 20rpx; }
.section-bar { width: 8rpx; height: 36rpx; background: linear-gradient(180deg, #5b9cf6, #38bdf8); border-radius: 4rpx; }
.section-title-text { font-size: 32rpx; font-weight: 700; color: #1e3a5f; }
.section-content { font-size: 30rpx; color: #374151; line-height: 1.9; display: block; }

.bottom-space { height: 32rpx; }

.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff; padding: 16rpx 28rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f3f4f6; box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
  display: flex; align-items: center; gap: 20rpx; z-index: 200;
}
.view-stat { display: flex; align-items: center; gap: 6rpx; }
.view-icon { font-size: 28rpx; }
.view-num { font-size: 26rpx; color: #9ca3af; }

.register-btn {
  flex: 1;
  background: linear-gradient(135deg, #5b9cf6, #4891e8);
  color: #fff; font-size: 32rpx; font-weight: 700;
  padding: 24rpx 0; border-radius: 50rpx; border: none;
  box-shadow: 0 6rpx 20rpx rgba(91, 156, 246, 0.3);
}
.register-btn.registered {
  background: linear-gradient(135deg, #34d399, #10b981);
  box-shadow: 0 6rpx 20rpx rgba(16, 185, 129, 0.3);
}
.register-btn.disabled {
  background: #e5e7eb; color: #9ca3af; box-shadow: none;
}
.register-btn::after { border: none; }
