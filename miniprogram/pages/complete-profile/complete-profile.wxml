<view class="page">
  <view class="card">
    <view class="title">首次登录请完善资料</view>
    <view class="sub">无需密码，完善后即可正常使用</view>

    <view class="field">
      <text class="label">昵称</text>
      <input class="ipt" value="{{username}}" bindinput="onUsernameInput" placeholder="请输入昵称（必填）" placeholder-class="ph" />
    </view>

    <view class="field">
      <text class="label">学号</text>
      <input class="ipt" value="{{studentNo}}" bindinput="onStudentNoInput" placeholder="请输入学号（必填）" placeholder-class="ph" maxlength="20" />
    </view>

    <view class="field">
      <text class="label">学院</text>
      <picker mode="selector" range="{{collegeList}}" range-key="name" value="{{collegeIndex}}" bindchange="onCollegeChange">
        <view class="picker">
          <text class="picker-text {{selectedCollege ? '' : 'ph'}}">{{selectedCollege || '请选择学院（必填）'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="field">
      <text class="label">手机号</text>
      <input class="ipt" value="{{phone}}" bindinput="onPhoneInput" placeholder="选填" placeholder-class="ph" maxlength="11" type="number" />
    </view>

    <view class="field">
      <text class="label">专业</text>
      <input class="ipt" value="{{major}}" bindinput="onMajorInput" placeholder="选填" placeholder-class="ph" maxlength="50" />
    </view>

    <view class="field">
      <text class="label">班级</text>
      <input class="ipt" value="{{className}}" bindinput="onClassInput" placeholder="选填" placeholder-class="ph" maxlength="20" />
    </view>

    <button class="btn {{isLoading?'loading':''}}" bindtap="onSubmit" disabled="{{isLoading}}">
      <text>提交并进入</text>
    </button>
  </view>
</view>

