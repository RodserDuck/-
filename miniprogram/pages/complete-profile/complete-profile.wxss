.page {
  min-height: 100vh;
  background: #f0f6ff;
  padding: 40rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(91, 156, 246, 0.12);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e3a5f;
}

.sub {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #94a3b8;
}

.field {
  margin-top: 28rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 10rpx;
}

.ipt, .picker {
  background: #f8fbff;
  border: 1rpx solid #e0efff;
  border-radius: 16rpx;
  padding: 22rpx 20rpx;
  font-size: 30rpx;
  color: #1e3a5f;
}

.ph {
  color: #c0d4ee;
}

.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.picker-text {
  flex: 1;
  min-width: 0;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  white-space: normal;
  word-break: break-all;
}

.arrow {
  flex-shrink: 0;
  font-size: 40rpx;
  color: #c0d4ee;
  line-height: 1;
  margin-left: 8rpx;
}

.btn {
  margin-top: 40rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #5b9cf6 0%, #4891e8 100%);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn.loading {
  opacity: 0.85;
}

