.page { min-height: 100vh; background: #f0f6ff; padding-bottom: 40rpx; }
.tabs { display: flex; background: #fff; margin: 18rpx 20rpx; border-radius: 18rpx; overflow: hidden; border: 1rpx solid #e5e7eb; }
.tab { flex: 1; text-align: center; padding: 22rpx 0; font-weight: 700; color: #64748b; }
.tab.active { color: #7c3aed; background: #f5f3ff; }
.section { padding: 0 20rpx; }
.toolbar { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; margin: 6rpx 0 14rpx; }
.hint { font-size: 22rpx; color: #94a3b8; }

.card { background: #fff; border-radius: 20rpx; padding: 22rpx 22rpx; margin-bottom: 14rpx; border: 1rpx solid #e5e7eb; }
.row { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; }
.title { font-size: 30rpx; font-weight: 800; color: #1e3a5f; flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.meta { margin-top: 10rpx; font-size: 24rpx; color: #64748b; }
.actions { margin-top: 14rpx; display: flex; gap: 20rpx; }
.link { font-size: 26rpx; font-weight: 700; color: #3b82f6; }
.link.danger { color: #ef4444; }

.badge { font-size: 22rpx; padding: 6rpx 14rpx; border-radius: 999rpx; font-weight: 700; }
.badge-0 { background: #f3f4f6; color: #6b7280; }
.badge-1 { background: #ede9fe; color: #6d28d9; }
.badge-2 { background: #dcfce7; color: #16a34a; }

.member-search { display: flex; gap: 12rpx; align-items: center; margin: 10rpx 0 14rpx; }
.input { flex: 1; background: #fff; border: 1rpx solid #e5e7eb; border-radius: 16rpx; padding: 18rpx 16rpx; font-size: 26rpx; }
.btn { background: #7c3aed; color: #fff; padding: 18rpx 22rpx; border-radius: 16rpx; font-weight: 700; font-size: 26rpx; }
.btn.ghost { background: #eef2ff; color: #4338ca; }
.btn.primary { background: #7c3aed; color: #fff; }

.member { background: #fff; border-radius: 18rpx; padding: 18rpx; display: flex; gap: 14rpx; align-items: center; border: 1rpx solid #e5e7eb; margin-bottom: 12rpx; }
.avatar { width: 80rpx; height: 80rpx; border-radius: 18rpx; background: #f3f4f6; }
.info { flex: 1; min-width: 0; }
.name-row { display: flex; align-items: center; gap: 10rpx; }
.name { font-size: 28rpx; font-weight: 800; color: #1e3a5f; max-width: 360rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.role { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 999rpx; background: #f3f4f6; color: #6b7280; font-weight: 700; }
.role.leader { background: #fef3c7; color: #b45309; }
.sub { display: block; margin-top: 6rpx; font-size: 22rpx; color: #64748b; }
.empty { text-align: center; color: #94a3b8; font-size: 26rpx; padding: 30rpx 0; }

.mask { position: fixed; left: 0; right: 0; top: 0; bottom: 0; background: rgba(15, 23, 42, 0.45); display: flex; align-items: flex-end; z-index: 999; }
.sheet { width: 100%; background: #fff; border-radius: 26rpx 26rpx 0 0; padding: 22rpx 20rpx 28rpx; max-height: 84vh; overflow: auto; }
.sheet-title { font-size: 32rpx; font-weight: 900; color: #1e3a5f; margin-bottom: 12rpx; }
.form { display: flex; flex-direction: column; gap: 14rpx; }
.field { display: flex; flex-direction: column; gap: 8rpx; }
.label { font-size: 22rpx; color: #64748b; font-weight: 700; }
.ipt { background: #f8fafc; border: 1rpx solid #e5e7eb; border-radius: 16rpx; padding: 16rpx 14rpx; font-size: 26rpx; }
.ta { background: #f8fafc; border: 1rpx solid #e5e7eb; border-radius: 16rpx; padding: 14rpx; min-height: 140rpx; font-size: 26rpx; }
.picker { background: #f8fafc; border: 1rpx solid #e5e7eb; border-radius: 16rpx; padding: 16rpx 14rpx; font-size: 26rpx; color: #111827; }
.sheet-actions { margin-top: 18rpx; display: flex; gap: 12rpx; }

