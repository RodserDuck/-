<view class="search-page">
  <!-- 顶部：胶囊搜索（可输入 + 右侧黑色搜索钮触发） -->
  <view class="search-sticky">
    <view class="capsule-search">
      <input
        class="capsule-search__input"
        type="text"
        value="{{inputValue}}"
        placeholder="按标题或内容搜索"
        placeholder-class="capsule-search__ph"
        bindinput="onInput"
        bindconfirm="onConfirm"
        confirm-type="search"
      />
      <view class="capsule-search__btn" catchtap="onConfirm">
        <icon type="search" size="18" color="#ffffff" />
      </view>
    </view>
  </view>

  <view class="scope-tabs">
    <view
      wx:for="{{scopes}}"
      wx:key="key"
      class="scope-tab {{scope === item.key ? 'active' : ''}}"
      bindtap="onScopeTap"
      data-key="{{item.key}}"
    >
      <text>{{item.label}}</text>
    </view>
  </view>

  <view class="loading-box" wx:if="{{loading}}">
    <text class="loading-text">搜索中...</text>
  </view>

  <view class="empty-box" wx:elif="{{!loading && keyword && emptyHint}}">
    <text class="empty-text">{{emptyHint}}</text>
  </view>

  <scroll-view
    class="result-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    wx:elif="{{!loading && results.length}}"
  >
    <view
      class="result-card"
      wx:for="{{results}}"
      wx:key="uid"
      bindtap="onResultTap"
      data-type="{{item.resultType}}"
      data-id="{{item.id}}"
    >
      <view class="result-tag">{{item.tag}}</view>
      <text class="result-title">{{item.title}}</text>
      <text class="result-desc" wx:if="{{item.desc}}">{{item.desc}}</text>
    </view>
    <view class="bottom-space"></view>
  </scroll-view>

  <view class="hint-box" wx:elif="{{!loading && !keyword}}">
    <text class="hint-text">选择分类后输入关键词，点击右侧图标搜索</text>
  </view>
</view>
