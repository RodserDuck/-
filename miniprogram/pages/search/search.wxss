.search-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: env(safe-area-inset-bottom);
}

.search-sticky {
  position: sticky;
  top: 0;
  z-index: 50;
  padding: 24rpx 28rpx 16rpx;
  padding-top: calc(16rpx + env(safe-area-inset-top));
  background: #fff;
  border-bottom: 1rpx solid #e5e5e5;
}

.scope-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 16rpx 24rpx 20rpx;
  background: #fff;
}

.scope-tab {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #525252;
  background: #f5f5f5;
  border: 2rpx solid transparent;
}

.scope-tab.active {
  color: #0a0a0a;
  background: #fff;
  border-color: #262626;
  font-weight: 600;
}

.loading-box,
.empty-box,
.hint-box {
  padding: 80rpx 48rpx;
  text-align: center;
}

.loading-text,
.empty-text,
.hint-text {
  font-size: 28rpx;
  color: #737373;
  line-height: 1.6;
}

.result-scroll {
  height: calc(100vh - 280rpx - env(safe-area-inset-top));
  padding: 8rpx 24rpx 0;
  box-sizing: border-box;
}

.result-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #e5e5e5;
}

.result-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #404040;
  background: #f5f5f5;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.result-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #0a0a0a;
  line-height: 1.4;
}

.result-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #737373;
  line-height: 1.5;
}

.bottom-space {
  height: 48rpx;
}
