/* pages/profile/profile.wxss - 柔和蓝白主题 · 个人中心页 */

/* ===================== 页面基础 ===================== */
.profile-page {
  min-height: 100vh;
  background: #f0f6ff;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===================== 顶部用户信息 ===================== */
.profile-header {
  background: linear-gradient(160deg, #5b9cf6 0%, #7dd3fc 60%, #bae6fd 100%);
  padding: 0;
  position: relative;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.05' fill-rule='evenodd'%3E%3Cpath d='M0 40L40 0H20L0 20M40 40V20L20 40'/%3E%3C/g%3E%3C/svg%3E") repeat;
}

.header-content {
  position: relative;
  z-index: 2;
  padding: 60rpx 28rpx 40rpx;
}

/* 用户信息 */
.user-info-section {
  display: flex;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.user-avatar-wrap {
  position: relative;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 5rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
}

.avatar-level {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  background: linear-gradient(135deg, #fb923c, #f97316);
  border-radius: 100rpx;
  padding: 4rpx 12rpx;
  border: 3rpx solid #fff;
}

.level-text {
  font-size: 18rpx;
  color: #fff;
  font-weight: 800;
}

.user-text-info {
  flex: 1;
  padding-top: 8rpx;
}

.user-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.3);
}

.user-identity-badge {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 100rpx;
  padding: 4rpx 14rpx;
}

.identity-text {
  font-size: 20rpx;
  color: #5b9cf6;
  font-weight: 700;
}

.user-account {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-bottom: 6rpx;
}

.user-motto {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

.edit-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  backdrop-filter: blur(8rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.edit-icon {
  font-size: 32rpx;
}

/* 数据统计卡片 */
.stats-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 24rpx 8rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 8rpx 32rpx rgba(59, 130, 246, 0.2);
  backdrop-filter: blur(8rpx);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  padding: 8rpx 0;
  border-right: 1rpx solid #f3f4f6;
}

.stat-item:last-child {
  border-right: none;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #1e3a5f;
  margin-bottom: 4rpx;
  line-height: 1;
}

.stat-label {
  font-size: 22rpx;
  color: #9ca3af;
  font-weight: 500;
}

/* ===================== 快捷功能 ===================== */
.quick-actions {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 28rpx 0;
}

.action-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  box-shadow: 0 4rpx 16rpx rgba(91, 156, 246, 0.08);
  transition: transform 0.15s, box-shadow 0.15s;
}

.action-card:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(91, 156, 246, 0.06);
}

.action-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.action-icon {
  font-size: 40rpx;
}

.action-name {
  font-size: 22rpx;
  color: #4b5563;
  font-weight: 500;
}

/* ===================== 菜单列表 ===================== */
.menu-section {
  padding: 24rpx 28rpx 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.menu-group {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 156, 246, 0.08);
  overflow: hidden;
}

.menu-group-header {
  padding: 20rpx 24rpx 12rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.group-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1e3a5f;
  letter-spacing: 1rpx;
}

.menu-group-body {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f9fafb;
  transition: background 0.15s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f8fbff;
}

.menu-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.menu-icon {
  font-size: 36rpx;
}

.menu-text-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.menu-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e3a5f;
  margin-bottom: 2rpx;
}

.menu-sub {
  font-size: 22rpx;
  color: #9ca3af;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.menu-count {
  background: #f87171;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 12rpx;
  border-radius: 100rpx;
  min-width: 36rpx;
  text-align: center;
}

.menu-arrow {
  font-size: 36rpx;
  color: #d1d5db;
  font-weight: 300;
}

/* ===================== 退出登录 ===================== */
.logout-section {
  padding: 32rpx 28rpx 0;
}

.logout-btn {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 156, 246, 0.08);
  transition: all 0.2s;
}

.logout-btn:active {
  background: #fef2f2;
  transform: scale(0.98);
}

.logout-icon {
  font-size: 36rpx;
}

.logout-text {
  font-size: 30rpx;
  color: #ef4444;
  font-weight: 600;
}

/* ===================== 底部信息 ===================== */
.footer-info {
  padding: 40rpx 24rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #9ca3af;
  font-weight: 500;
}

.footer-sub {
  font-size: 20rpx;
  color: #c0d0e8;
}
