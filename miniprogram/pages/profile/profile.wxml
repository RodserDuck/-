<!-- pages/profile/profile.wxml -->
<view class="profile-page">
  <!-- 顶部用户信息卡片 -->
  <view class="profile-header">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="user-info-section">
        <view class="user-avatar-wrap">
          <image class="user-avatar" src="{{userInfo.avatar}}" mode="aspectFill"/>
        </view>
        <view class="user-text-info">
          <view class="user-name-row">
            <text class="user-name">{{userInfo.nickname}}</text>
            <view class="user-identity-badge">
              <text class="identity-text">{{userInfo.identity === 'student' ? '学生' : userInfo.identity === 'teacher' ? '教师' : '管理员'}}</text>
            </view>
          </view>
          <text class="user-account" wx:if="{{userInfo.account}}">账号: {{userInfo.account}}</text>
          <text class="user-motto">让校园生活更便捷 ✨</text>
        </view>
        <view class="edit-btn" bindtap="onEditProfile">
          <text class="edit-icon">✏️</text>
        </view>
      </view>

      <!-- 数据统计 -->
      <view class="stats-card">
        <view class="stat-item" wx:for="{{statsList}}" wx:key="id">
          <text class="stat-value">{{item.value}}</text>
          <text class="stat-label">{{item.label}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 快捷功能 -->
  <view class="quick-actions">
    <view class="action-card" wx:for="{{quickActions}}" wx:key="id" bindtap="onQuickAction" data-id="{{item.id}}">
      <view class="action-icon-wrap" style="background: {{item.bgColor}}">
        <image class="action-icon-img" src="{{item.iconSrc}}" mode="aspectFit"/>
      </view>
      <text class="action-name">{{item.name}}</text>
    </view>
  </view>

  <!-- 主菜单列表 -->
  <view class="menu-section">
    <view class="menu-group" wx:for="{{menuGroups}}" wx:key="title">
      <view class="menu-group-header">
        <text class="group-title">{{item.title}}</text>
      </view>
      <view class="menu-group-body">
        <view
          class="menu-item"
          wx:for="{{item.items}}"
          wx:for-item="menuItem"
          wx:key="id"
          bindtap="onMenuTap"
          data-id="{{menuItem.id}}"
        >
          <view class="menu-icon-wrap" style="background: {{menuItem.iconBg}}">
            <text class="menu-icon">{{menuItem.icon}}</text>
          </view>
          <view class="menu-text-wrap">
            <text class="menu-name">{{menuItem.name}}</text>
            <text class="menu-sub" wx:if="{{menuItem.sub}}">{{menuItem.sub}}</text>
          </view>
          <view class="menu-right">
            <view class="trade-badge" wx:if="{{menuItem.id === 10 && tradeStats.pendingCount > 0}}">
              <text class="badge-num">{{tradeStats.pendingCount}}</text>
            </view>
            <text class="menu-arrow">›</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <view class="logout-btn" bindtap="onLogout">
      <text class="logout-icon">🚪</text>
      <text class="logout-text">退出登录</text>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer-info">
    <text class="footer-text">校园生活服务平台 v2.0</text>
    <text class="footer-sub">九江学院 · 计算机与大数据科学学院</text>
  </view>

  <!-- 交易记录弹窗 -->
  <view class="trade-sheet-mask" wx:if="{{showTradeSheet}}" bindtap="closeTradeSheet">
    <view class="trade-sheet" catchtap="">
      <view class="trade-sheet-header">
        <text class="trade-sheet-title">{{tradeTab === 'buy' ? '我的购买' : '我的售出'}}</text>
        <view class="trade-sheet-close" bindtap="closeTradeSheet">
          <text>×</text>
        </view>
      </view>

      <!-- 切换标签 -->
      <view class="trade-tabs">
        <view class="trade-tab {{tradeTab === 'buy' ? 'active' : ''}}" bindtap="showTradeSheet" data-tab="buy">
          <text>购买记录</text>
        </view>
        <view class="trade-tab {{tradeTab === 'sell' ? 'active' : ''}}" bindtap="showTradeSheet" data-tab="sell">
          <text>售出记录</text>
        </view>
      </view>

      <!-- 购买列表 -->
      <scroll-view class="trade-list" scroll-y wx:if="{{tradeTab === 'buy'}}">
        <view class="empty-trade" wx:if="{{buyList.length === 0}}">
          <text class="empty-emoji">🛒</text>
          <text class="empty-text">还没有购买记录</text>
        </view>
        <view class="trade-record-item" wx:for="{{buyList}}" wx:key="id">
          <view class="record-header">
            <text class="record-title">{{item.itemTitle}}</text>
            <view class="record-status {{item.status === 1 ? 'done' : item.status === 2 ? 'canceled' : 'pending'}}">
              <text>{{item.status === 0 ? '等待确认' : item.status === 1 ? '已完成' : '已取消'}}</text>
            </view>
          </view>
          <view class="record-info">
            <text class="record-price">¥{{item.price}}</text>
            <text class="record-time">{{item.createTime}}</text>
          </view>
          <view class="record-seller" wx:if="{{item.sellerName}}">
            <text>卖家：{{item.sellerName}}</text>
          </view>
          <view class="record-remark" wx:if="{{item.remark}}">
            <text>留言：{{item.remark}}</text>
          </view>
          <view class="record-tip" wx:if="{{item.status === 0}}">
            <text>请与卖家线下交易后，确认收货</text>
          </view>
          <view class="record-actions" wx:if="{{item.status === 0}}">
            <view class="record-btn confirm" bindtap="onBuyerConfirm" data-id="{{item.recordId}}" data-title="{{item.itemTitle}}">
              <text>✅ 确认收货</text>
            </view>
            <view class="record-btn cancel" bindtap="onBuyerCancel" data-id="{{item.recordId}}">
              <text>❌ 取消</text>
            </view>
          </view>
        </view>
      </scroll-view>

      <!-- 售出列表 -->
      <scroll-view class="trade-list" scroll-y wx:if="{{tradeTab === 'sell'}}">
        <view class="empty-trade" wx:if="{{sellList.length === 0}}">
          <text class="empty-emoji">💰</text>
          <text class="empty-text">还没有售出记录</text>
        </view>
        <view class="trade-record-item" wx:for="{{sellList}}" wx:key="id">
          <view class="record-header">
            <text class="record-title">{{item.itemTitle}}</text>
            <view class="record-status {{item.status === 1 ? 'done' : item.status === 2 ? 'canceled' : 'pending'}}">
              <text>{{item.status === 0 ? '待确认' : item.status === 1 ? '已完成' : '已取消'}}</text>
            </view>
          </view>
          <view class="record-info">
            <text class="record-price">¥{{item.price}}</text>
            <text class="record-time">{{item.createTime}}</text>
          </view>
          <view class="record-seller" wx:if="{{item.buyerName}}">
            <text>买家：{{item.buyerName}}</text>
          </view>
          <view class="record-tip" wx:if="{{item.status === 0}}">
            <text>请与买家线下交易后，在商品详情页确认完成</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
