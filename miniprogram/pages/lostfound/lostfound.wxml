<!-- pages/lostfound/lostfound.wxml -->
<view class="lostfound-page">
  <!-- 顶部标题栏 -->
  <view class="top-bar">
    <view class="top-bar-bg"></view>
    <view class="top-content">
      <text class="top-title">失物招领</text>
      <text class="top-sub">让遗失物品更快回到主人身边</text>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-section">
    <view class="search-bar">
      <view class="search-icon">🔍</view>
      <input
        class="search-input"
        type="text"
        placeholder="搜索标题或物品说明..."
        placeholder-class="search-placeholder"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
      />
      <view class="filter-btn" bindtap="onFilterTap">
        <text class="filter-icon">🔽</text>
      </view>
    </view>
  </view>

  <!-- 快速发布按钮 -->
  <view class="quick-publish">
    <view class="publish-btn lost-publish" bindtap="onPublishLost">
      <view class="publish-icon-wrap">
        <text class="publish-icon">🔍</text>
      </view>
      <view class="publish-text-wrap">
        <text class="publish-title">发布寻物</text>
        <text class="publish-sub">我丢失了物品</text>
      </view>
      <text class="publish-arrow">›</text>
    </view>
    <view class="publish-btn found-publish" bindtap="onPublishFound">
      <view class="publish-icon-wrap" style="background: rgba(52, 211, 153, 0.15)">
        <text class="publish-icon">📦</text>
      </view>
      <view class="publish-text-wrap">
        <text class="publish-title">发布招领</text>
        <text class="publish-sub">我捡到了物品</text>
      </view>
      <text class="publish-arrow">›</text>
    </view>
  </view>

  <!-- Tab标签 -->
  <view class="tab-bar">
    <view class="tab-item {{currentTab === 0 ? 'active' : ''}}" bindtap="onTabChange" data-index="0">
      <view class="tab-icon-wrap">
        <text class="tab-icon">🔍</text>
      </view>
      <text class="tab-text">寻物启事</text>
      <view class="tab-count">{{lostItems.length}}</view>
    </view>
    <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" bindtap="onTabChange" data-index="1">
      <view class="tab-icon-wrap" style="background: rgba(52, 211, 153, 0.12)">
        <text class="tab-icon" style="font-size: 28rpx">📦</text>
      </view>
      <text class="tab-text">失物招领</text>
      <view class="tab-count" style="background: rgba(52, 211, 153, 0.15); color: #059669">{{foundItems.length}}</view>
    </view>
  </view>

  <!-- ==================== 寻物启事列表 ==================== -->
  <view class="tab-content" wx:if="{{currentTab === 0}}">
    <view class="item-list">
      <view
        class="item-card lost-card {{item.status === '已找回' ? 'resolved' : ''}}"
        wx:for="{{lostItems}}"
        wx:key="id"
        bindtap="onItemTap"
        data-id="{{item.id}}"
        data-type="lost"
      >
        <view class="item-image-wrap" wx:if="{{item.image}}">
          <image class="item-image" src="{{item.image}}" mode="aspectFill"/>
          <view class="item-type-corner lost-corner">
            <text class="corner-text">寻物</text>
          </view>
        </view>
        <view class="item-image-wrap no-image" wx:else>
          <text class="no-image-icon">{{item.type === 'lost' ? '🔍' : '📦'}}</text>
          <view class="item-type-corner {{item.type === 'lost' ? 'lost-corner' : 'found-corner'}}">
            <text class="corner-text">{{item.type === 'lost' ? '寻物' : '招领'}}</text>
          </view>
        </view>
        <view class="item-info">
          <view class="item-header">
            <text class="item-title">{{item.title}}</text>
            <view class="item-status-badge {{item.status === '已找回' ? 'resolved' : 'searching'}}">
              <text class="status-text">{{item.status}}</text>
            </view>
          </view>
          <text class="item-desc">{{item.description}}</text>
          <view class="item-meta">
            <view class="meta-row">
              <text class="meta-icon">📍</text>
              <text class="meta-text">{{item.location}}</text>
            </view>
            <view class="meta-row">
              <text class="meta-icon">🕐</text>
              <text class="meta-text">{{item.time}}</text>
            </view>
          </view>
          <view class="item-footer">
            <text class="contact-text">联系方式: {{item.contact}}</text>
            <view class="contact-btn" bindtap="onContactTap" data-contact="{{item.contact}}">
              <text class="contact-btn-text">联系</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ==================== 失物招领列表 ==================== -->
  <view class="tab-content" wx:if="{{currentTab === 1}}">
    <view class="item-list">
      <view
        class="item-card found-card {{item.status === '已归还' ? 'resolved' : ''}}"
        wx:for="{{foundItems}}"
        wx:key="id"
        bindtap="onItemTap"
        data-id="{{item.id}}"
        data-type="found"
      >
        <view class="item-image-wrap" wx:if="{{item.image}}">
          <image class="item-image" src="{{item.image}}" mode="aspectFill"/>
          <view class="item-type-corner found-corner">
            <text class="corner-text">招领</text>
          </view>
        </view>
        <view class="item-image-wrap no-image found-no-image" wx:else>
          <text class="no-image-icon">📦</text>
          <view class="item-type-corner found-corner">
            <text class="corner-text">招领</text>
          </view>
        </view>
        <view class="item-info">
          <view class="item-header">
            <text class="item-title">{{item.title}}</text>
            <view class="item-status-badge {{item.status === '已归还' ? 'resolved-found' : 'waiting'}}">
              <text class="status-text">{{item.status}}</text>
            </view>
          </view>
          <text class="item-desc">{{item.description}}</text>
          <view class="item-meta">
            <view class="meta-row">
              <text class="meta-icon">📍</text>
              <text class="meta-text">{{item.location}}</text>
            </view>
            <view class="meta-row">
              <text class="meta-icon">🕐</text>
              <text class="meta-text">{{item.time}}</text>
            </view>
          </view>
          <view class="item-footer">
            <text class="contact-text">联系方式: {{item.contact}}</text>
            <view class="contact-btn found-btn" bindtap="onContactTap" data-contact="{{item.contact}}">
              <text class="contact-btn-text">认领</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-space"></view>
</view>
