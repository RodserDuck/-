<view class="page">
  <view class="hero">
    <text class="hero-title">失物招领</text>
    <text class="hero-sub">按流程提交、认领、审核，状态全程可见</text>
  </view>

  <view class="publish-row">
    <view class="publish-btn lost" bindtap="onPublishLost">发布寻物</view>
    <view class="publish-btn found" bindtap="onPublishFound">发布招领</view>
  </view>

  <view class="tab-row">
    <view class="tab {{currentTab===0?'active':''}}" data-index="0" bindtap="onTabChange">寻物</view>
    <view class="tab {{currentTab===1?'active':''}}" data-index="1" bindtap="onTabChange">招领</view>
  </view>

  <view class="search-row">
    <input class="search-input" placeholder="搜索标题/物品/描述" value="{{keyword}}" bindinput="onKeywordInput" confirm-type="search" bindconfirm="onSearch" />
    <view class="search-btn" bindtap="onSearch">查询</view>
  </view>

  <view class="filter-row">
    <view class="chip {{statusFilter===''?'on':''}}" data-status="" bindtap="onStatusFilterChange">全部</view>
    <view class="chip {{statusFilter===0?'on':''}}" data-status="{{0}}" bindtap="onStatusFilterChange">待处理</view>
    <view class="chip {{statusFilter===1?'on':''}}" data-status="{{1}}" bindtap="onStatusFilterChange">进行中</view>
    <view class="chip {{statusFilter===2?'on':''}}" data-status="{{2}}" bindtap="onStatusFilterChange">已找到</view>
  </view>

  <view class="list">
    <view class="card" wx:for="{{items}}" wx:key="id" bindtap="onItemTap" data-id="{{item.id}}">
      <image wx:if="{{item.image}}" class="thumb" src="{{item.image}}" mode="aspectFill"></image>
      <view wx:else class="thumb empty">暂无图片</view>
      <view class="body">
        <view class="line1">
          <text class="title">{{item.title}}</text>
          <text class="status {{item.statusClass}}">{{item.statusText}}</text>
        </view>
        <text class="meta">{{item.itemName || '未填写物品'}} · {{item.time}}</text>
        <text class="desc">{{item.description}}</text>
        <text class="meta">地点：{{item.location}}</text>
      </view>
    </view>
    <view wx:if="{{!loading && items.length===0}}" class="empty-text">暂无数据</view>
  </view>
</view>
