/* pages/lostfound/lostfound.wxss - 柔和蓝白主题 · 失物招领页 */

/* ===================== 页面基础 ===================== */
.lostfound-page {
  min-height: 100vh;
  background: #f0f6ff;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===================== 顶部标题栏 ===================== */
.top-bar {
  background: linear-gradient(160deg, #5b9cf6 0%, #7dd3fc 60%, #bae6fd 100%);
  padding: 24rpx 28rpx 0;
  position: relative;
  overflow: hidden;
}

.top-bar-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.06'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E") repeat;
}

.top-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0 40rpx;
}

.top-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 6rpx;
  text-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

.top-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 8rpx;
  letter-spacing: 1rpx;
}

/* ===================== 搜索栏 ===================== */
.search-section {
  padding: 0 28rpx;
  margin-top: -20rpx;
  position: relative;
  z-index: 10;
}

.lostfound-search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.lostfound-search-row .capsule-search {
  flex: 1;
  min-width: 0;
}

.filter-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eef6ff;
  border-radius: 50%;
  flex-shrink: 0;
}

.filter-icon {
  font-size: 28rpx;
}

/* ===================== 快速发布 ===================== */
.quick-publish {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 28rpx 0;
}

.publish-btn {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(91, 156, 246, 0.08);
  gap: 16rpx;
  transition: all 0.2s;
}

.publish-btn:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(91, 156, 246, 0.06);
}

.lost-publish {
  border-left: 6rpx solid #5b9cf6;
}

.found-publish {
  border-left: 6rpx solid #34d399;
}

.publish-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  background: rgba(91, 156, 246, 0.12);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.publish-icon {
  font-size: 36rpx;
}

.publish-text-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.publish-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e3a5f;
  margin-bottom: 4rpx;
}

.publish-sub {
  font-size: 22rpx;
  color: #9ca3af;
}

.publish-arrow {
  font-size: 36rpx;
  color: #d1d5db;
  font-weight: 300;
}

/* ===================== Tab标签栏 ===================== */
.tab-bar {
  display: flex;
  background: #fff;
  margin: 20rpx 28rpx 0;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(91, 156, 246, 0.08);
  overflow: hidden;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 24rpx 0;
  position: relative;
  transition: all 0.25s;
}

.tab-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  background: rgba(91, 156, 246, 0.12);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  font-size: 26rpx;
}

.tab-text {
  font-size: 28rpx;
  color: #9ca3af;
  font-weight: 500;
  transition: color 0.25s;
}

.tab-item.active .tab-text {
  color: #1e3a5f;
  font-weight: 700;
}

.tab-count {
  background: rgba(91, 156, 246, 0.1);
  color: #5b9cf6;
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 12rpx;
  border-radius: 100rpx;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 10%;
  right: 10%;
  height: 4rpx;
  background: linear-gradient(90deg, #5b9cf6, #38bdf8);
  border-radius: 2rpx;
}

/* ===================== 内容区 ===================== */
.tab-content {
  padding: 20rpx 28rpx 0;
}

/* ===================== 物品卡片列表 ===================== */
.item-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-bottom: 24rpx;
}

.item-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 156, 246, 0.08);
  overflow: hidden;
  display: flex;
  gap: 0;
  transition: box-shadow 0.2s;
}

.item-card:active {
  box-shadow: 0 2rpx 12rpx rgba(91, 156, 246, 0.06);
}

.lost-card {
  border-left: 6rpx solid #5b9cf6;
}

.found-card {
  border-left: 6rpx solid #34d399;
}

.item-card.resolved {
  opacity: 0.6;
}

/* 卡片左侧图片 */
.item-image-wrap {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  flex-shrink: 0;
  overflow: hidden;
}

.item-image {
  width: 100%;
  height: 100%;
}

.item-image-wrap.no-image {
  background: #f0f9ff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.no-image-icon {
  font-size: 64rpx;
  opacity: 0.3;
}

.found-no-image {
  background: #ecfdf5;
}

/* 左上角类型标签 */
.item-type-corner {
  position: absolute;
  top: 12rpx;
  left: 0;
  border-radius: 0 12rpx 12rpx 0;
  padding: 6rpx 16rpx 6rpx 12rpx;
}

.lost-corner {
  background: linear-gradient(135deg, #5b9cf6, #3b82f6);
}

.found-corner {
  background: linear-gradient(135deg, #34d399, #10b981);
}

.corner-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 700;
}

/* 卡片右侧信息 */
.item-info {
  flex: 1;
  padding: 20rpx;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.item-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.item-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e3a5f;
  line-height: 1.3;
  flex: 1;
}

.item-status-badge {
  border-radius: 100rpx;
  padding: 4rpx 14rpx;
  flex-shrink: 0;
}

.item-status-badge.searching {
  background: #fef3c7;
  border: 1rpx solid #fde68a;
}

.item-status-badge.resolved {
  background: #f3f4f6;
  border: 1rpx solid #e5e7eb;
}

.item-status-badge.waiting {
  background: #dcfce7;
  border: 1rpx solid #bbf7d0;
}

.item-status-badge.resolved-found {
  background: #f3f4f6;
  border: 1rpx solid #e5e7eb;
}

.status-text {
  font-size: 20rpx;
  font-weight: 600;
}

.item-status-badge.searching .status-text {
  color: #d97706;
}

.item-status-badge.resolved .status-text {
  color: #9ca3af;
}

.item-status-badge.waiting .status-text {
  color: #059669;
}

.item-status-badge.resolved-found .status-text {
  color: #9ca3af;
}

.item-desc {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-meta {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 12rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-icon {
  font-size: 22rpx;
}

.meta-text {
  font-size: 22rpx;
  color: #9ca3af;
}

.item-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 12rpx;
  border-top: 1rpx solid #f3f4f6;
  margin-top: auto;
}

.contact-text {
  font-size: 22rpx;
  color: #9ca3af;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.contact-btn {
  background: linear-gradient(135deg, #5b9cf6, #4891e8);
  border-radius: 100rpx;
  padding: 10rpx 28rpx;
  flex-shrink: 0;
  transition: all 0.15s;
}

.contact-btn:active {
  transform: scale(0.95);
}

.found-btn {
  background: linear-gradient(135deg, #34d399, #10b981);
}

.contact-btn-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}

/* 底部占位 */
.bottom-space {
  height: 40rpx;
}
