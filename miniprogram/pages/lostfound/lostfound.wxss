page { background: #f4f7fc; }
.page { padding: 24rpx; }
.hero { padding: 28rpx; border-radius: 24rpx; background: linear-gradient(135deg, #2563eb, #0ea5e9); color: #fff; }
.hero-title { display: block; font-size: 44rpx; font-weight: 700; }
.hero-sub { display: block; margin-top: 8rpx; font-size: 24rpx; opacity: 0.9; }

.publish-row { margin-top: 20rpx; display: flex; gap: 16rpx; }
.publish-btn { flex: 1; text-align: center; border-radius: 16rpx; padding: 20rpx 0; color: #fff; font-size: 28rpx; font-weight: 600; }
.publish-btn.lost { background: #2563eb; }
.publish-btn.found { background: #059669; }

.tab-row { margin-top: 20rpx; display: flex; background: #fff; border-radius: 14rpx; padding: 8rpx; }
.tab { flex: 1; text-align: center; padding: 12rpx 0; border-radius: 10rpx; color: #64748b; font-size: 26rpx; }
.tab.active { background: #e0ecff; color: #1d4ed8; font-weight: 600; }

.search-row { margin-top: 16rpx; display: flex; gap: 12rpx; }
.search-input { flex: 1; background: #fff; border-radius: 12rpx; height: 72rpx; padding: 0 22rpx; font-size: 26rpx; }
.search-btn { width: 120rpx; text-align: center; background: #1d4ed8; color: #fff; border-radius: 12rpx; line-height: 72rpx; font-size: 26rpx; }

.filter-row { margin-top: 16rpx; display: flex; gap: 10rpx; flex-wrap: wrap; }
.chip { padding: 10rpx 18rpx; border-radius: 999rpx; font-size: 22rpx; color: #64748b; background: #e2e8f0; }
.chip.on { color: #fff; background: #1d4ed8; }

.list { margin-top: 18rpx; display: flex; flex-direction: column; gap: 14rpx; }
.card { background: #fff; border-radius: 16rpx; overflow: hidden; display: flex; }
.thumb { width: 180rpx; height: 180rpx; background: #e2e8f0; flex-shrink: 0; }
.thumb.empty { display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 22rpx; }
.body { flex: 1; padding: 16rpx; min-width: 0; }
.line1 { display: flex; gap: 10rpx; justify-content: space-between; align-items: center; }
.title { flex: 1; font-size: 28rpx; color: #0f172a; font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.status { font-size: 20rpx; padding: 4rpx 10rpx; border-radius: 999rpx; }
.status.pending { background: #fef3c7; color: #b45309; }
.status.active { background: #dbeafe; color: #1d4ed8; }
.status.done { background: #dcfce7; color: #166534; }
.meta { display: block; margin-top: 8rpx; font-size: 22rpx; color: #64748b; }
.desc { display: block; margin-top: 8rpx; font-size: 24rpx; color: #334155; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.empty-text { text-align: center; color: #94a3b8; padding: 50rpx 0; font-size: 24rpx; }
