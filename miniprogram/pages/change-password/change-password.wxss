/* pages/change-password/change-password.wxss */
page { background: #f0f6ff; }
.page { min-height: 100vh; padding: 24rpx 28rpx; box-sizing: border-box; }

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(91,156,246,0.08);
}

.title { font-size: 36rpx; font-weight: 800; color: #1e3a5f; }
.sub { margin-top: 6rpx; font-size: 24rpx; color: #9ca3af; }

.form { margin-top: 28rpx; display: flex; flex-direction: column; gap: 20rpx; }
.item { display: flex; align-items: center; gap: 16rpx; background: #f8fafc; border-radius: 16rpx; padding: 20rpx 24rpx; }
.label { width: 130rpx; flex-shrink: 0; font-size: 26rpx; font-weight: 700; color: #1e3a5f; }
.input { flex: 1; font-size: 28rpx; color: #374151; }

.actions { margin-top: 32rpx; display: flex; gap: 16rpx; }
.btn { flex: 1; padding: 22rpx 0; border-radius: 18rpx; display: flex; align-items: center; justify-content: center; font-size: 30rpx; font-weight: 700; }
.btn.primary { background: linear-gradient(135deg, #5b9cf6, #4891e8); color: #fff; box-shadow: 0 6rpx 20rpx rgba(91,156,246,0.35); }
.btn.ghost { background: #f3f4f6; color: #9ca3af; }

