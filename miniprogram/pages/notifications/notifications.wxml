<!-- pages/notifications/notifications.wxml -->
<view class="page">
  <view class="notif-list" wx:if="{{!empty}}">
    <view
      class="notif-card {{item.isTop ? 'top' : ''}}"
      wx:for="{{notifications}}"
      wx:key="id"
      bindtap="onNotifTap"
      data-id="{{item.id}}"
    >
      <view class="notif-header">
        <text class="notif-title">{{item.title}}</text>
        <view class="top-badge" wx:if="{{item.isTop}}">
          <text class="top-text">置顶</text>
        </view>
      </view>
      <text class="notif-content">{{item.content}}</text>
      <text class="notif-time">{{item.time}}</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{empty && !loading}}">
    <text class="empty-emoji">🔔</text>
    <text class="empty-title">暂无通知</text>
    <text class="empty-sub">平台公告和系统通知将在这里显示</text>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>
</view>
