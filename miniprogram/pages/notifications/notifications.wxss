/* pages/notifications/notifications.wxss */
page { background: #f0f6ff; }
.page { min-height: 100vh; padding: 24rpx 28rpx; }

.notif-list { display: flex; flex-direction: column; gap: 16rpx; }

.notif-card {
  background: #fff; border-radius: 20rpx;
  padding: 24rpx; box-shadow: 0 4rpx 20rpx rgba(91,156,246,0.08);
  display: flex; flex-direction: column; gap: 12rpx;
}

.notif-card.top { border-left: 6rpx solid #5b9cf6; }

.notif-header { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; }
.notif-title { font-size: 30rpx; font-weight: 700; color: #1e3a5f; flex: 1; }
.top-badge { background: linear-gradient(135deg, #fbbf24, #f59e0b); border-radius: 100rpx; padding: 4rpx 14rpx; flex-shrink: 0; }
.top-text { font-size: 20rpx; color: #fff; font-weight: 700; }
.notif-content { font-size: 26rpx; color: #6b7280; line-height: 1.6; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.notif-time { font-size: 22rpx; color: #9ca3af; }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 24rpx; gap: 16rpx; }
.empty-emoji { font-size: 96rpx; opacity: 0.3; }
.empty-title { font-size: 32rpx; font-weight: 600; color: #374151; }
.empty-sub { font-size: 26rpx; color: #9ca3af; }

.loading-state { display: flex; justify-content: center; padding: 60rpx; }
.loading-text { font-size: 28rpx; color: #9ca3af; }
