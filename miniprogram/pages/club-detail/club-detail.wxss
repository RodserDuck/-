/* pages/club-detail/club-detail.wxss */
page { background: #f5f5f5; }
.container { min-height: 100vh; padding-bottom: 140rpx; }

.club-banner { position: relative; height: 400rpx; }
.banner-image { width: 100%; height: 100%; }
.banner-overlay { position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(to top, rgba(0,0,0,0.7), transparent); padding: 40rpx; display: flex; flex-direction: column; align-items: center; }
.club-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.club-name { font-size: 40rpx; font-weight: bold; color: #fff; margin-bottom: 8rpx; }
.club-category { font-size: 26rpx; color: rgba(255,255,255,0.8); background: rgba(139, 92, 246, 0.8); padding: 6rpx 20rpx; border-radius: 20rpx; }

.info-section { background: #fff; padding: 30rpx; margin-bottom: 20rpx; }
.stat-row { display: flex; justify-content: space-around; }
.stat-item { display: flex; flex-direction: column; align-items: center; }
.stat-value { font-size: 40rpx; font-weight: bold; color: #333; margin-bottom: 8rpx; }
.stat-label { font-size: 26rpx; color: #999; }

.section { background: #fff; padding: 30rpx; margin-bottom: 20rpx; }
.section-title { font-size: 32rpx; font-weight: bold; color: #333; margin-bottom: 24rpx; }
.description-text { font-size: 30rpx; color: #666; line-height: 1.8; }

.activity-list { display: flex; flex-direction: column; gap: 20rpx; }
.activity-item { display: flex; justify-content: space-between; align-items: center; padding: 24rpx; background: #f8f9fa; border-radius: 12rpx; }
.activity-info { display: flex; flex-direction: column; }
.activity-title { font-size: 30rpx; color: #333; font-weight: 500; margin-bottom: 8rpx; }
.activity-time { font-size: 26rpx; color: #999; }
.activity-status { font-size: 24rpx; padding: 8rpx 16rpx; border-radius: 8rpx; }
.activity-status.ongoing { background: #dcfce7; color: #16a34a; }
.activity-status.ended { background: #f3f4f6; color: #6b7280; }

.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 20rpx 30rpx; border-top: 1rpx solid #f0f0f0; }
.join-btn { background: linear-gradient(135deg, #8b5cf6, #a78bfa); color: #fff; font-size: 32rpx; font-weight: bold; padding: 24rpx 0; border-radius: 40rpx; text-align: center; }
.join-btn.joined { background: #e5e7eb; color: #9ca3af; }
.join-btn.applying { background: #fef3c7; color: #f59e0b; }
