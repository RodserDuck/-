/* pages/club-detail/club-detail.wxss */
page { background: #f0f6ff; }
.detail-page { min-height: 100vh; display: flex; flex-direction: column; }

.nav-bar {
  display: flex; justify-content: space-between; align-items: center;
  background: linear-gradient(135deg, #7c3aed 0%, #a78bfa 100%);
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  position: sticky; top: 0; z-index: 200;
}
.nav-back { width: 60rpx; height: 60rpx; display: flex; align-items: center; justify-content: center; }
.back-icon { font-size: 52rpx; color: #fff; font-weight: bold; line-height: 1; }
.nav-title { font-size: 34rpx; font-weight: 700; color: #fff; flex: 1; text-align: center; }
.nav-placeholder { width: 60rpx; }

.main-scroll { flex: 1; padding-bottom: 140rpx; }

/* 社团头图 */
.club-header { position: relative; height: 400rpx; overflow: hidden; }
.header-bg { width: 100%; height: 100%; }
.header-overlay {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: linear-gradient(to top, rgba(91, 30, 135, 0.85), transparent);
  padding: 40rpx 32rpx 32rpx;
  display: flex; flex-direction: column; align-items: center;
}
.club-icon-badge {
  width: 100rpx; height: 100rpx; background: rgba(255,255,255,0.2);
  border-radius: 24rpx; backdrop-filter: blur(8rpx);
  border: 3rpx solid rgba(255,255,255,0.4);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 16rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.2);
}
.icon-emoji { font-size: 56rpx; }
.header-name { font-size: 42rpx; font-weight: 800; color: #fff; margin-bottom: 12rpx; text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3); }
.category-badge {
  background: rgba(255,255,255,0.25); border-radius: 100rpx;
  padding: 6rpx 24rpx; backdrop-filter: blur(4rpx);
}
.category-text { font-size: 24rpx; color: #fff; font-weight: 600; }

/* 统计数据 */
.stats-card {
  background: #fff; margin: 20rpx; border-radius: 24rpx;
  padding: 28rpx; display: flex; align-items: center; justify-content: space-around;
  box-shadow: 0 4rpx 20rpx rgba(91, 156, 246, 0.08);
}
.stat-item { display: flex; flex-direction: column; align-items: center; }
.stat-value { font-size: 44rpx; font-weight: 800; color: #1e3a5f; margin-bottom: 4rpx; line-height: 1; }
.stat-label { font-size: 24rpx; color: #9ca3af; }
.stat-divider { width: 1rpx; height: 60rpx; background: #f3f4f6; }

/* 通用卡片 */
.section-card {
  background: #fff; margin: 0 20rpx 20rpx; border-radius: 24rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 156, 246, 0.08);
}
.section-title-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 20rpx; }
.section-bar { width: 8rpx; height: 36rpx; background: linear-gradient(180deg, #7c3aed, #a78bfa); border-radius: 4rpx; }
.section-title-text { font-size: 32rpx; font-weight: 700; color: #1e3a5f; }
.section-content { font-size: 30rpx; color: #374151; line-height: 1.9; display: block; }
.contact-row { display: flex; align-items: center; gap: 8rpx; margin-top: 20rpx; padding-top: 20rpx; border-top: 1rpx solid #f3f4f6; }
.contact-icon { font-size: 28rpx; }
.contact-value { font-size: 28rpx; color: #5b9cf6; font-weight: 500; }

/* 活动列表 */
.empty-acts { display: flex; flex-direction: column; align-items: center; gap: 12rpx; padding: 40rpx 0; }
.empty-emoji { font-size: 60rpx; opacity: 0.3; }
.empty-text { font-size: 28rpx; color: #9ca3af; }

.act-list { display: flex; flex-direction: column; gap: 16rpx; }
.act-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 24rpx; background: #f8fafc; border-radius: 16rpx;
  border: 1rpx solid #f1f5f9; transition: background 0.15s;
}
.act-item:active { background: #eff6ff; }
.act-info { display: flex; flex-direction: column; gap: 8rpx; flex: 1; min-width: 0; }
.act-title { font-size: 28rpx; font-weight: 600; color: #1e3a5f; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.act-time { font-size: 22rpx; color: #9ca3af; }
.act-status {
  border-radius: 100rpx; padding: 6rpx 18rpx; font-size: 22rpx; font-weight: 600; flex-shrink: 0; margin-left: 16rpx;
}
.act-status.open { background: linear-gradient(135deg, #dbeafe, #bfdbfe); color: #2563eb; }
.act-status.ongoing { background: linear-gradient(135deg, #d1fae5, #a7f3d0); color: #059669; }
.act-status.closed { background: #f3f4f6; color: #9ca3af; }

.bottom-space { height: 32rpx; }

/* 底部操作栏 */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff; padding: 16rpx 28rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f3f4f6; box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
  z-index: 200;
}
.bottom-bar {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.manage-btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eef2ff;
  border: 1rpx solid #c7d2fe;
}

.manage-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #4338ca;
}
.join-btn {
  flex: 1; padding: 24rpx 0; border-radius: 50rpx;
  display: flex; align-items: center; justify-content: center;
}
.join-btn {
  background: linear-gradient(135deg, #7c3aed, #8b5cf6);
  box-shadow: 0 6rpx 20rpx rgba(124, 58, 237, 0.35);
}
.join-btn.joined {
  background: #f3f4f6; box-shadow: none;
}
.join-btn.pending {
  background: linear-gradient(135deg, #fbbf24, #f59e0b);
  box-shadow: 0 6rpx 20rpx rgba(245, 158, 11, 0.3);
}
.join-text { font-size: 32rpx; font-weight: 700; color: #fff; }
.join-btn.joined .join-text { color: #9ca3af; }
.join-btn.pending .join-text { color: #fff; }
