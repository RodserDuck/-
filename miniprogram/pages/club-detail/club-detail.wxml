<!-- pages/club-detail/club-detail.wxml -->
<view class="detail-page" wx:if="{{club}}">
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="onBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="nav-title">社团详情</text>
    <view class="nav-placeholder"></view>
  </view>

  <scroll-view class="main-scroll" scroll-y>
    <!-- 社团头图 -->
    <view class="club-header">
      <image
        class="header-bg"
        src="{{club.coverImage || 'https://picsum.photos/750/450?random=20'}}"
        mode="aspectFill"
      />
      <view class="header-overlay">
        <view class="club-icon-badge">
          <text class="icon-emoji">🏘️</text>
        </view>
        <text class="header-name">{{club.name}}</text>
        <view class="category-badge">
          <text class="category-text">{{club.category}}</text>
        </view>
      </view>
    </view>

    <!-- 统计数据 -->
    <view class="stats-card">
      <view class="stat-item">
        <text class="stat-value">{{club.memberCount || 0}}</text>
        <text class="stat-label">成员</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{activities.length || 0}}</text>
        <text class="stat-label">活动</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{club.contact ? '有' : '无'}}</text>
        <text class="stat-label">联系方式</text>
      </view>
    </view>

    <!-- 社团简介 -->
    <view class="section-card">
      <view class="section-title-row">
        <view class="section-bar"></view>
        <text class="section-title-text">社团简介</text>
      </view>
      <text class="section-content">{{club.description || '暂无简介'}}</text>
      <view class="contact-row" wx:if="{{club.contact}}">
        <text class="contact-icon">📞</text>
        <text class="contact-value">{{club.contact}}</text>
      </view>
    </view>

    <!-- 近期活动 -->
    <view class="section-card">
      <view class="section-title-row">
        <view class="section-bar"></view>
        <text class="section-title-text">近期活动</text>
      </view>
      <view class="empty-acts" wx:if="{{activities.length === 0}}">
        <text class="empty-emoji">📅</text>
        <text class="empty-text">暂无活动</text>
      </view>
      <view class="act-list" wx:else>
        <view
          class="act-item"
          wx:for="{{activities}}"
          wx:key="id"
          bindtap="onActivityTap"
          data-id="{{item.id}}"
        >
          <view class="act-info">
            <text class="act-title">{{item.title}}</text>
            <text class="act-time">📅 {{item.time}}</text>
          </view>
          <view class="act-status {{item.statusClass}}">
            <text>{{item.status}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-space"></view>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <!-- 已加入 -->
    <view class="join-btn joined" wx:if="{{joinStatus === 'joined'}}" bindtap="onJoinTap">
      <text class="join-text">✓ 已加入</text>
    </view>
    <!-- 审核中 -->
    <view class="join-btn pending" wx:elif="{{joinStatus === 'pending'}}">
      <text class="join-text">⏳ 审核中</text>
    </view>
    <!-- 未加入 -->
    <view class="join-btn" wx:else bindtap="onJoinTap">
      <text class="join-text">申请加入</text>
    </view>
  </view>
</view>
