<!-- pages/goods-detail/goods-detail.wxml -->
<view class="detail-page">
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="onBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="nav-title">商品详情</text>
    <view class="nav-placeholder"></view>
  </view>

  <scroll-view class="main-scroll" scroll-y wx:if="{{goods}}">
    <!-- 图片轮播 -->
    <view class="image-section">
      <swiper class="image-swiper" indicator-dots autoplay circular interval="3000" bindchange="onSwiperChange">
        <swiper-item wx:for="{{goods.images}}" wx:key="*this">
          <image src="{{item}}" mode="aspectFill" class="goods-image" bindtap="onPreviewImage" data-src="{{item}}"/>
        </swiper-item>
      </swiper>
      <view class="image-indicator">{{currentImageIndex + 1}}/{{goods.images.length}}</view>
      <!-- 状态标签 -->
      <view class="status-overlay {{goods.statusCode === 2 ? 'sold' : ''}}" wx:if="{{goods.statusCode !== 1}}">
        <text class="status-overlay-text">{{goods.status}}</text>
      </view>
    </view>

    <!-- 价格 + 标题 -->
    <view class="price-section">
      <view class="price-row">
        <text class="current-price">¥{{goods.price}}</text>
        <text class="original-price" wx:if="{{goods.originalPrice}}">原价 ¥{{goods.originalPrice}}</text>
        <view class="condition-tag">
          <text class="condition-text">{{goods.condition}}</text>
        </view>
      </view>
      <text class="goods-title">{{goods.title}}</text>
      <view class="meta-row">
        <view class="meta-item">
          <text class="meta-icon">📍</text>
          <text class="meta-text">{{goods.location}}</text>
        </view>
        <view class="status-badge {{goods.statusCode === 1 ? 'onsale' : 'sold'}}">
          <text class="status-badge-text">{{goods.status}}</text>
        </view>
      </view>
    </view>

    <!-- 商品描述 -->
    <view class="section-card">
      <view class="section-title-row">
        <view class="section-bar"></view>
        <text class="section-title-text">商品描述</text>
      </view>
      <text class="description-text">{{goods.description}}</text>
    </view>

    <!-- 卖家信息 -->
    <view class="section-card">
      <view class="section-title-row">
        <view class="section-bar"></view>
        <text class="section-title-text">卖家信息</text>
      </view>
      <view class="seller-card">
        <image class="seller-avatar" src="{{goods.seller.avatar}}" mode="aspectFill"/>
        <view class="seller-info">
          <text class="seller-name">{{goods.seller.nickname}}</text>
          <text class="seller-college" wx:if="{{goods.seller.college}}">{{goods.seller.college}}</text>
        </view>
        <view class="seller-contact-btn" bindtap="onContactTap">
          <text class="contact-icon">💬</text>
        </view>
      </view>
      <view class="contact-tip" wx:if="{{goods.contact}}">
        <text class="contact-label">联系方式：</text>
        <text class="contact-value">{{goods.contact}}</text>
      </view>
    </view>

    <!-- 卖家视角：待处理交易请求 -->
    <view class="section-card" wx:if="{{isOwner && tradeList.length > 0}}">
      <view class="section-title-row">
        <view class="section-bar" style="background: linear-gradient(180deg, #fbbf24, #f59e0b);"></view>
        <text class="section-title-text">待确认交易</text>
      </view>
      <view class="trade-list">
        <view class="trade-item" wx:for="{{tradeList}}" wx:key="id">
          <view class="trade-header">
            <text class="trade-title">买家：{{item.buyerName}}</text>
            <view class="trade-status pending">
              <text class="trade-status-text">待确认</text>
            </view>
          </view>
          <text class="trade-remark" wx:if="{{item.remark}}">留言：{{item.remark}}</text>
          <text class="trade-time">发起时间：{{item.createTime}}</text>
          <view class="trade-actions">
            <view class="trade-btn confirm" bindtap="onConfirmTrade" data-id="{{item.recordId}}">
              <text>✅ 确认完成</text>
            </view>
            <view class="trade-btn cancel" bindtap="onCancelTrade" data-id="{{item.recordId}}">
              <text>❌ 取消</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-space"></view>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar" wx:if="{{goods}}">
    <!-- 卖家视角 -->
    <view wx:if="{{isOwner}}" class="owner-actions">
      <view class="action-chip" bindtap="onMyTradeTap">
        <text class="chip-icon">📋</text>
        <text class="chip-text">交易记录</text>
      </view>
      <view class="action-tip-text">您是卖家，等待买家发起交易</view>
    </view>

    <!-- 非卖家视角 -->
    <view wx:else class="buyer-actions">
      <view class="action-chip" bindtap="onLikeTap">
        <text class="action-icon">{{goods.isLiked ? '❤️' : '🤍'}}</text>
        <text class="chip-text">收藏</text>
      </view>
      <view class="action-chip" bindtap="onContactTap">
        <text class="action-icon">💬</text>
        <text class="chip-text">联系卖家</text>
      </view>
      <button
        class="buy-btn {{goods.statusCode !== 1 ? 'disabled' : ''}}"
        bindtap="onBuyTap"
        disabled="{{goods.statusCode !== 1}}"
      >
        {{goods.statusCode === 1 ? '立即购买' : goods.status}}
      </button>
    </view>
  </view>
</view>
