/* pages/goods-detail/goods-detail.wxss */
page { background: #f5f5f5; }
.container { padding-bottom: 140rpx; }

.image-section {
  position: relative;
  background: #fff;
}

.image-swiper {
  height: 640rpx;
}

.goods-image {
  width: 100%;
  height: 100%;
}

.image-indicator {
  position: absolute;
  bottom: 24rpx;
  right: 32rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 26rpx;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
}

.price-section {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.price-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.current-price {
  font-size: 52rpx;
  color: #ef4444;
  font-weight: 600;
  margin-right: 24rpx;
}

.original-price {
  font-size: 28rpx;
  color: #999;
  text-decoration: line-through;
  margin-right: 24rpx;
}

.condition-tag {
  background: #fef3c7;
  color: #f59e0b;
  font-size: 26rpx;
  padding: 8rpx 18rpx;
  border-radius: 10rpx;
}

.goods-title {
  font-size: 38rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.5;
  display: block;
  margin-bottom: 20rpx;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  color: #666;
}

.status.onsale {
  color: #16a34a;
}

.status.sold {
  color: #999;
}

.section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.description {
  font-size: 30rpx;
  color: #666;
  line-height: 1.8;
}

.seller-card {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.seller-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.seller-nickname {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 24rpx;
  color: #666;
  padding: 0 20rpx;
}

.action-btn.liked {
  color: #ef4444;
}

.buy-btn {
  flex: 1;
  background: linear-gradient(135deg, #f59e0b, #fbbf24);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 24rpx 0;
  border-radius: 40rpx;
  border: none;
  margin: 0;
}

.buy-btn[disabled] {
  background: #e5e7eb;
  color: #9ca3af;
}
