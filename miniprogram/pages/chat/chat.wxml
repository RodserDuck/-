<!-- pages/chat/chat.wxml -->
<view class="container">
  <!-- 商品信息栏 -->
  <view class="goods-bar">
    <image class="goods-thumb" src="{{goods.image}}" mode="aspectFill"/>
    <view class="goods-info">
      <text class="goods-title">{{goods.title}}</text>
      <text class="goods-price">¥{{goods.price}}</text>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view class="message-list" scroll-y>
    <view class="message-item {{item.type}}" wx:for="{{messages}}" wx:key="id">
      <!-- 对方消息 -->
      <view wx:if="{{item.type === 'other'}}" class="other-message">
        <image class="avatar" src="{{item.avatar}}" mode="aspectFill"/>
        <view class="bubble">{{item.content}}</view>
      </view>
      
      <!-- 自己消息 -->
      <view wx:if="{{item.type === 'self'}}" class="self-message">
        <view class="bubble">{{item.content}}</view>
        <image class="avatar" src="{{item.avatar}}" mode="aspectFill"/>
      </view>
    </view>
  </scroll-view>

  <!-- 输入栏 -->
  <view class="input-bar">
    <input type="text" placeholder="请输入消息..." value="{{inputValue}}" bindinput="onInput"/>
    <button bindtap="onSend">发送</button>
  </view>
</view>
