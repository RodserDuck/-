/* pages/chat/chat.wxss */
page { background: #f5f5f5; }
.container { height: 100vh; display: flex; flex-direction: column; }

.goods-bar {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.goods-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.goods-info {
  flex: 1;
}

.goods-title {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.goods-price {
  font-size: 30rpx;
  color: #ef4444;
  font-weight: bold;
}

.message-list {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

.message-item {
  margin-bottom: 30rpx;
}

.other-message {
  display: flex;
  align-items: flex-start;
}

.self-message {
  display: flex;
  justify-content: flex-end;
  align-items: flex-start;
}

.avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.bubble {
  max-width: 60%;
  padding: 20rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  margin: 0 20rpx;
}

.other-message .bubble {
  background: #fff;
  border-top-left-radius: 4rpx;
}

.self-message .bubble {
  background: #3b82f6;
  color: #fff;
  border-top-right-radius: 4rpx;
}

.input-bar {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
  gap: 20rpx;
}

.input-bar input {
  flex: 1;
  background: #f5f5f5;
  padding: 16rpx 24rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
}

.input-bar button {
  background: #3b82f6;
  color: #fff;
  font-size: 28rpx;
  padding: 0 30rpx;
  border-radius: 30rpx;
  line-height: 2.2;
}
