<!-- pages/settings/settings.wxml -->
<view class="page">
  <!-- 用户信息 -->
  <view class="user-card" wx:if="{{userInfo}}">
    <view class="user-avatar-wrap">
      <image class="user-avatar" src="{{userInfo.avatar || 'https://picsum.photos/200/200?random=99'}}" mode="aspectFill"/>
    </view>
    <view class="user-info">
      <text class="user-nickname">{{userInfo.username || userInfo.nickname || '校园用户'}}</text>
      <text class="user-account" wx:if="{{userInfo.studentNo}}">学号: {{userInfo.studentNo}}</text>
      <text class="user-college" wx:if="{{userInfo.college}}">{{userInfo.college}}</text>
    </view>
    <view class="edit-btn" bindtap="onEditProfile">
      <text class="edit-icon">✏️</text>
    </view>
  </view>

  <!-- 设置菜单 -->
  <view class="settings-group">
    <view class="settings-title">账号设置</view>
    <view class="settings-item" bindtap="onEditProfile">
      <text class="settings-icon">👤</text>
      <text class="settings-name">编辑资料</text>
      <text class="settings-arrow">›</text>
    </view>
    <view class="settings-item">
      <text class="settings-icon">🔒</text>
      <text class="settings-name">修改密码</text>
      <text class="settings-arrow">›</text>
    </view>
  </view>

  <view class="settings-group">
    <view class="settings-title">通用设置</view>
    <view class="settings-item">
      <text class="settings-icon">🔔</text>
      <text class="settings-name">通知提醒</text>
      <text class="settings-arrow">›</text>
    </view>
    <view class="settings-item">
      <text class="settings-icon">🌙</text>
      <text class="settings-name">深色模式</text>
      <text class="settings-arrow">›</text>
    </view>
    <view class="settings-item">
      <text class="settings-icon">🗑️</text>
      <text class="settings-name">清除缓存</text>
      <text class="settings-arrow">›</text>
    </view>
  </view>

  <view class="settings-group">
    <view class="settings-title">关于</view>
    <view class="settings-item">
      <text class="settings-icon">ℹ️</text>
      <text class="settings-name">关于我们</text>
      <text class="settings-arrow">›</text>
    </view>
    <view class="settings-item">
      <text class="settings-icon">📋</text>
      <text class="settings-name">用户协议</text>
      <text class="settings-arrow">›</text>
    </view>
    <view class="settings-item">
      <text class="settings-icon">🔒</text>
      <text class="settings-name">隐私政策</text>
      <text class="settings-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <view class="logout-btn" bindtap="onLogout">
      <text class="logout-text">退出登录</text>
    </view>
  </view>

  <view class="version-info">
    <text class="version-text">校园生活服务平台 v2.0</text>
  </view>

  <!-- 编辑资料弹窗 -->
  <view class="edit-mask" wx:if="{{showEditModal}}" bindtap="onCancelEdit">
    <view class="edit-sheet" catchtap="">
      <view class="edit-sheet-header">
        <text class="edit-sheet-title">编辑资料</text>
        <view class="edit-close" bindtap="onCancelEdit">×</view>
      </view>
      <view class="edit-form">
        <view class="edit-item">
          <text class="edit-label">昵称</text>
          <input class="edit-input" value="{{editNickname}}" bindinput="onNicknameInput" placeholder="请输入昵称" maxlength="20"/>
        </view>
        <view class="edit-item">
          <text class="edit-label">手机号</text>
          <input class="edit-input" value="{{editPhone}}" bindinput="onPhoneInput" placeholder="请输入手机号" maxlength="11" type="number"/>
        </view>
      </view>
      <view class="edit-actions">
        <view class="edit-btn cancel" bindtap="onCancelEdit">
          <text>取消</text>
        </view>
        <view class="edit-btn save" bindtap="onSaveProfile">
          <text>保存</text>
        </view>
      </view>
    </view>
  </view>
</view>
