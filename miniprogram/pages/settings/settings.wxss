/* pages/settings/settings.wxss */
page { background: #f0f6ff; }
.page { min-height: 100vh; padding: 24rpx 28rpx; }

.user-card {
  background: linear-gradient(160deg, #5b9cf6 0%, #7dd3fc 60%, #bae6fd 100%);
  border-radius: 24rpx; padding: 32rpx;
  display: flex; align-items: center; gap: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(59,130,246,0.2);
  margin-bottom: 24rpx;
}
.user-avatar-wrap {}
.user-avatar { width: 120rpx; height: 120rpx; border-radius: 50%; border: 5rpx solid rgba(255,255,255,0.9); box-shadow: 0 8rpx 24rpx rgba(59,130,246,0.3); }
.user-info { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.user-nickname { font-size: 36rpx; font-weight: 800; color: #fff; text-shadow: 0 2rpx 8rpx rgba(59,130,246,0.3); }
.user-account, .user-college { font-size: 24rpx; color: rgba(255,255,255,0.75); }
.edit-btn { width: 72rpx; height: 72rpx; background: rgba(255,255,255,0.25); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; border: 2rpx solid rgba(255,255,255,0.3); }
.edit-icon { font-size: 36rpx; }

.settings-group { background: #fff; border-radius: 24rpx; margin-bottom: 20rpx; overflow: hidden; box-shadow: 0 4rpx 20rpx rgba(91,156,246,0.08); }
.settings-title { padding: 20rpx 24rpx 12rpx; font-size: 26rpx; font-weight: 700; color: #1e3a5f; border-bottom: 1rpx solid #f3f4f6; letter-spacing: 1rpx; }
.settings-item { display: flex; align-items: center; padding: 24rpx; border-bottom: 1rpx solid #f9fafb; transition: background 0.15s; }
.settings-item:last-child { border-bottom: none; }
.settings-item:active { background: #f8fbff; }
.settings-icon { font-size: 36rpx; margin-right: 16rpx; flex-shrink: 0; }
.settings-name { flex: 1; font-size: 30rpx; font-weight: 600; color: #1e3a5f; }
.settings-arrow { font-size: 36rpx; color: #d1d5db; font-weight: 300; }

.logout-section { margin-top: 16rpx; }
.logout-btn { background: #fff; border-radius: 24rpx; padding: 28rpx; display: flex; align-items: center; justify-content: center; gap: 12rpx; box-shadow: 0 4rpx 20rpx rgba(91,156,246,0.08); transition: all 0.2s; }
.logout-btn:active { background: #fef2f2; transform: scale(0.98); }
.logout-text { font-size: 30rpx; color: #ef4444; font-weight: 600; }

.version-info { display: flex; justify-content: center; padding: 40rpx 0 24rpx; }
.version-text { font-size: 22rpx; color: #c0d0e8; font-weight: 500; }

/* 编辑资料弹窗 */
.edit-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 500; display: flex; align-items: flex-end; }
.edit-sheet { width: 100%; background: #f0f6ff; border-radius: 32rpx 32rpx 0 0; overflow: hidden; }
.edit-sheet-header { display: flex; align-items: center; justify-content: space-between; padding: 32rpx 32rpx 24rpx; border-bottom: 1rpx solid #e8f2ff; }
.edit-sheet-title { font-size: 34rpx; font-weight: 700; color: #1e3a5f; }
.edit-close { width: 60rpx; height: 60rpx; background: #f3f4f6; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 44rpx; color: #9ca3af; line-height: 1; }
.edit-form { padding: 24rpx 32rpx; display: flex; flex-direction: column; gap: 24rpx; }
.edit-item { display: flex; align-items: center; gap: 16rpx; background: #fff; border-radius: 16rpx; padding: 20rpx 24rpx; }
.edit-label { font-size: 28rpx; font-weight: 600; color: #1e3a5f; width: 120rpx; flex-shrink: 0; }
.edit-input { flex: 1; font-size: 28rpx; color: #374151; }
.edit-actions { display: flex; gap: 16rpx; padding: 0 32rpx 32rpx; }
.edit-btn { flex: 1; display: flex; align-items: center; justify-content: center; padding: 24rpx; border-radius: 20rpx; font-size: 30rpx; font-weight: 600; }
.edit-btn.cancel { background: #f3f4f6; color: #9ca3af; }
.edit-btn.save { background: linear-gradient(135deg, #5b9cf6, #4891e8); color: #fff; box-shadow: 0 6rpx 20rpx rgba(91,156,246,0.35); }
