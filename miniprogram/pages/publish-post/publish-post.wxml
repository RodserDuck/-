<!-- pages/publish-post/publish-post.wxml -->
<view class="container">
  <!-- 帖子分区选择 -->
  <view class="category-bar">
    <text class="category-label">选择分区</text>
    <scroll-view class="category-scroll" scroll-x>
      <view class="category-list">
        <view
          class="category-item {{currentCategory === item.value ? 'active' : ''}}"
          wx:for="{{categories}}"
          wx:key="value"
          bindtap="onCategoryTap"
          data-value="{{item.value}}"
        >
          <text class="category-text">{{item.label}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 内容输入 -->
  <textarea
    class="content-input"
    placeholder="分享你的校园生活..."
    value="{{content}}"
    bindinput="onContentInput"
    maxlength="500"
  />

  <!-- 图片上传 -->
  <view class="image-section">
    <view class="section-title">图片（选填）</view>
    <view class="image-grid">
      <view class="image-item" wx:for="{{images}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" class="uploaded-image"/>
        <view class="delete-btn" bindtap="onDeleteImage" data-index="{{index}}">
          <text>×</text>
        </view>
      </view>
      <view class="add-btn" wx:if="{{images.length < maxImages}}" bindtap="onChooseImage">
        <text class="add-icon">+</text>
        <text class="add-text">{{images.length}}/{{maxImages}}</text>
      </view>
    </view>
  </view>

  <!-- 底部占位（为固定发布栏留空间） -->
  <view class="bottom-space"></view>

  <!-- 底部固定发布按钮 -->
  <view class="bottom-publish-bar">
    <view
      class="publish-btn-full {{isSubmitting ? 'disabled' : ''}}"
      bindtap="onPublish"
    >
      <text class="btn-icon">✏️</text>
      <text class="btn-text">发布帖子</text>
    </view>
  </view>
</view>
