<!-- pages/login/login.wxml -->
<view class="login-page">
  <!-- 顶部装饰区域 -->
  <view class="top-area">
    <view class="cloud cloud-1"></view>
    <view class="cloud cloud-2"></view>
    <view class="cloud cloud-3"></view>
    <!-- Logo区域 -->
    <view class="logo-zone">
      <view class="logo-circle">
        <view class="logo-icon">🏫</view>
      </view>
      <view class="logo-text-wrap">
        <text class="app-name">校园生活服务平台</text>
        <text class="app-sub">Campus Life Service</text>
      </view>
    </view>
    <!-- 波浪分隔线 -->
    <view class="wave-divider">
      <view class="wave wave-1"></view>
      <view class="wave wave-2"></view>
    </view>
  </view>

  <!-- 表单区域 -->
  <view class="form-area">
    <view class="form-card">
      <!-- 标题 -->
      <view class="form-title">
        <text class="welcome-text">欢迎回来</text>
        <text class="welcome-sub">连接校园，精彩生活</text>
      </view>

      <!-- 输入框组 -->
      <view class="input-group">
        <view class="input-item">
          <view class="input-icon">
            <text class="iconfont">👤</text>
          </view>
          <view class="input-field">
            <text class="input-label">账号</text>
            <input
              class="input-control"
              type="text"
              placeholder="请输入学号/账号"
              placeholder-class="input-placeholder"
              value="{{account}}"
              bindinput="onAccountInput"
              maxlength="20"
            />
          </view>
        </view>

        <view class="input-divider"></view>

        <view class="input-item">
          <view class="input-icon">
            <text class="iconfont">🔒</text>
          </view>
          <view class="input-field">
            <text class="input-label">密码</text>
            <input
              class="input-control"
              password
              placeholder="请输入密码"
              placeholder-class="input-placeholder"
              value="{{password}}"
              bindinput="onPasswordInput"
              maxlength="18"
            />
          </view>
        </view>
      </view>

      <!-- 选项行 -->
      <view class="options-row">
        <view class="remember-wrap">
          <view class="remember-btn {{rememberMe ? 'checked' : ''}}" bindtap="onRememberChange">
            <view class="checkbox {{rememberMe ? 'checked' : ''}}">
              <text wx:if="{{rememberMe}}" class="check-icon">✓</text>
            </view>
            <text class="remember-text">记住我</text>
          </view>
        </view>
        <text class="forgot-link" bindtap="onForgotPassword">忘记密码？</text>
      </view>

      <!-- 登录按钮 -->
      <button
        class="login-btn {{isLoading ? 'loading' : ''}}"
        bindtap="onLogin"
        disabled="{{isLoading}}"
      >
        <text wx:if="{{!isLoading}}" class="btn-text-main">登 录</text>
        <view wx:if="{{isLoading}}" class="loading-wrap">
          <view class="loading-dot"></view>
          <view class="loading-dot"></view>
          <view class="loading-dot"></view>
        </view>
      </button>

      <!-- 注册提示 -->
      <view class="register-row">
        <text class="register-tip">还没有账号？</text>
        <text class="register-link" bindtap="onGoRegister">立即注册</text>
      </view>
    </view>

    <!-- 底部装饰 -->
    <view class="bottom-decoration">
      <text class="decoration-dot"></text>
      <text class="decoration-line"></text>
      <text class="decoration-dot"></text>
    </view>

    <!-- 演示说明 -->
    <view class="demo-tip">
      <text class="demo-text">演示模式 · 输入任意账号密码即可登录</text>
    </view>
  </view>
</view>
