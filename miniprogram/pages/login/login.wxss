/* pages/login/login.wxss - 柔和蓝白主题登录页 */

/* ===================== 页面结构 ===================== */
.login-page {
  min-height: 100vh;
  background: #f0f6ff;
  display: flex;
  flex-direction: column;
  overflow-x: hidden;
}

/* ===================== 顶部装饰区域 ===================== */
.top-area {
  background: linear-gradient(160deg, #5b9cf6 0%, #7dd3fc 55%, #bae6fd 100%);
  position: relative;
  padding-bottom: 0;
  overflow: hidden;
  min-height: 460rpx;
}

/* 云朵装饰 */
.cloud {
  position: absolute;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 100rpx;
}

.cloud-1 {
  width: 200rpx;
  height: 80rpx;
  top: 60rpx;
  left: -40rpx;
  animation: float 8s ease-in-out infinite;
}

.cloud-2 {
  width: 280rpx;
  height: 100rpx;
  top: 30rpx;
  right: -60rpx;
  animation: float 10s ease-in-out infinite 2s;
}

.cloud-3 {
  width: 160rpx;
  height: 60rpx;
  top: 160rpx;
  left: 60rpx;
  animation: float 12s ease-in-out infinite 4s;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

/* Logo 区域 */
.logo-zone {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
  position: relative;
  z-index: 2;
}

.logo-circle {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(59, 130, 246, 0.35);
  margin-bottom: 32rpx;
  animation: fadeInUp 0.8s ease-out;
}

.logo-icon {
  font-size: 80rpx;
  line-height: 1;
}

.logo-text-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: fadeInUp 0.8s ease-out 0.15s both;
}

.app-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
  text-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
  margin-bottom: 10rpx;
}

.app-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  letter-spacing: 3rpx;
}

/* 波浪分隔线 */
.wave-divider {
  position: relative;
  margin-top: 60rpx;
  height: 60rpx;
  overflow: hidden;
}

.wave {
  position: absolute;
  bottom: 0;
  width: 200%;
  height: 60rpx;
  background: #f0f6ff;
  border-radius: 40% 40% 0 0;
}

.wave-1 {
  left: 0;
  z-index: 1;
}

.wave-2 {
  left: -50%;
  z-index: 2;
  background: linear-gradient(180deg, #e8f2ff 0%, #f0f6ff 100%);
}

/* ===================== 表单区域 ===================== */
.form-area {
  flex: 1;
  padding: 48rpx 48rpx 40rpx;
  background: #f0f6ff;
  position: relative;
  z-index: 3;
}

.form-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(91, 156, 246, 0.12);
  animation: fadeInUp 0.8s ease-out 0.3s both;
}

/* 表单标题 */
.form-title {
  margin-bottom: 48rpx;
}

.welcome-text {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #1e3a5f;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.welcome-sub {
  display: block;
  font-size: 26rpx;
  color: #a0b4d0;
  letter-spacing: 1rpx;
}

/* ===================== 输入框 ===================== */
.input-group {
  background: #f8fbff;
  border-radius: 20rpx;
  border: 1rpx solid #e0efff;
  margin-bottom: 28rpx;
  overflow: hidden;
  transition: border-color 0.25s;
}

.input-group:focus-within {
  border-color: #5b9cf6;
  box-shadow: 0 0 0 4rpx rgba(91, 156, 246, 0.1);
}

.input-item {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  min-height: 112rpx;
}

.input-icon {
  width: 72rpx;
  height: 72rpx;
  background: #eef6ff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.input-icon .iconfont {
  font-size: 36rpx;
}

.input-divider {
  height: 1rpx;
  background: #e8f2ff;
  margin: 0 28rpx;
}

.input-field {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.input-label {
  font-size: 22rpx;
  color: #a0b4d0;
  font-weight: 500;
  margin-bottom: 4rpx;
  letter-spacing: 1rpx;
}

.input-control {
  font-size: 30rpx;
  color: #1e3a5f;
  font-weight: 500;
  padding: 0;
  background: transparent;
  line-height: 1.4;
}

.input-placeholder {
  color: #c0d4ee;
  font-weight: 400;
}

/* ===================== 选项行 ===================== */
.options-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 36rpx;
}

.remember-wrap {
  display: flex;
  align-items: center;
}

.remember-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #c0d4ee;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  flex-shrink: 0;
}

.checkbox.checked {
  background: linear-gradient(135deg, #5b9cf6, #38bdf8);
  border-color: #5b9cf6;
}

.check-icon {
  font-size: 22rpx;
  color: #fff;
  font-weight: 700;
}

.remember-text {
  font-size: 26rpx;
  color: #6b8cbe;
}

.forgot-link {
  font-size: 26rpx;
  color: #5b9cf6;
  font-weight: 500;
}

/* ===================== 登录按钮 ===================== */
.login-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #5b9cf6 0%, #4891e8 100%);
  border: none;
  border-radius: 50rpx;
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  box-shadow: 0 8rpx 32rpx rgba(91, 156, 246, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s;
  margin-bottom: 32rpx;
}

.login-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 16rpx rgba(91, 156, 246, 0.25);
}

.login-btn.loading {
  opacity: 0.8;
}

.wx-btn {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  box-shadow: 0 8rpx 32rpx rgba(34, 197, 94, 0.25);
  letter-spacing: 2rpx;
}

.btn-text-main {
  letter-spacing: 6rpx;
}

.loading-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.loading-dot {
  width: 12rpx;
  height: 12rpx;
  background: #fff;
  border-radius: 50%;
  animation: bounce 1.2s ease-in-out infinite;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* ===================== 注册提示 ===================== */
.register-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
}

.register-tip {
  font-size: 26rpx;
  color: #9ca3af;
}

.register-link {
  font-size: 28rpx;
  color: #5b9cf6;
  font-weight: 600;
}

/* ===================== 底部装饰 ===================== */
.bottom-decoration {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 40rpx;
  animation: fadeIn 1s ease-out 0.6s both;
}

.decoration-dot {
  width: 8rpx;
  height: 8rpx;
  background: #c0d4ee;
  border-radius: 50%;
}

.decoration-line {
  width: 80rpx;
  height: 2rpx;
  background: #d8e8fa;
  border-radius: 2rpx;
}

/* ===================== 演示说明 ===================== */
.demo-tip {
  text-align: center;
  margin-top: 24rpx;
  animation: fadeIn 1s ease-out 0.8s both;
}

.demo-text {
  font-size: 22rpx;
  color: #b0c8e8;
  letter-spacing: 1rpx;
}

/* ===================== 动画 ===================== */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
