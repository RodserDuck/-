/* pages/college/college.wxss - 学院广场页 */
page {
  background-color: #f0f6ff;
}

.container {
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  flex: 1;
  text-align: center;
}

.nav-placeholder { width: 60rpx; }

.college-search-wrap {
  padding: 0 24rpx 24rpx;
  margin-top: -8rpx;
}

/* 通知列表 */
.notice-list {
  padding: 24rpx 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 30rpx; color: #9ca3af; }

.notice-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
  transition: box-shadow 0.2s;
}

.notice-card:active {
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.06);
}

.notice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.notice-tag {
  background: #eef2ff;
  color: #667eea;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 18rpx;
  border-radius: 100rpx;
}

.default-tag {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

.notice-time {
  font-size: 24rpx;
  color: #9ca3af;
}

.notice-title {
  font-size: 30rpx;
  color: #1e3a5f;
  font-weight: 600;
  line-height: 1.5;
  display: block;
  margin-bottom: 8rpx;
}

.notice-preview {
  font-size: 26rpx;
  color: #9ca3af;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.5;
}

/* 加载 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.loading-dots { display: flex; gap: 12rpx; margin-bottom: 16rpx; }

.dot {
  width: 14rpx;
  height: 14rpx;
  background: #667eea;
  border-radius: 50%;
  animation: bounce 1.2s ease-in-out infinite;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

.loading-text { font-size: 26rpx; color: #9ca3af; }
