<!-- pages/college/college.wxml -->
<view class="container">
  <!-- 顶部导航栏 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="onBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="nav-title">{{collegeName || '学院广场'}}</text>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 通知列表 -->
  <view class="notice-list">
    <view class="empty-state" wx:if="{{notices.length === 0 && !loading}}">
      <text class="empty-icon">🏛</text>
      <text class="empty-text">暂无学院公告</text>
    </view>
    <view class="notice-card" wx:for="{{notices}}" wx:key="id" bindtap="onViewDetail" data-id="{{item.id}}">
      <view class="notice-header">
        <text class="notice-tag">学院</text>
        <text class="notice-time">{{item.time}}</text>
      </view>
      <text class="notice-title">{{item.title}}</text>
    </view>
  </view>
</view>
