/* pages/post-detail/post-detail.wxss */
page { background: #f5f5f5; }
.container { padding-bottom: 120rpx; }

.post-card {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.time {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.content {
  font-size: 34rpx;
  color: #333;
  line-height: 1.7;
  margin-bottom: 24rpx;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.post-image {
  width: 230rpx;
  height: 230rpx;
  border-radius: 16rpx;
}

.post-actions {
  display: flex;
  gap: 48rpx;
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  font-size: 30rpx;
  color: #666;
}

.action-btn.liked {
  color: #ef4444;
}

.comment-section {
  background: #fff;
  padding: 32rpx;
  min-height: 400rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.comment-item {
  display: flex;
  margin-bottom: 30rpx;
}

.comment-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.comment-content {
  flex: 1;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.comment-nickname {
  font-size: 28rpx;
  color: #3b82f6;
}

.comment-time {
  font-size: 24rpx;
  color: #999;
}

.comment-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.5;
}

.comment-footer {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #999;
}

.comment-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  gap: 20rpx;
}

.comment-bar input {
  flex: 1;
  background: #f5f5f5;
  padding: 16rpx 24rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
}

.comment-bar button {
  background: #3b82f6;
  color: #fff;
  font-size: 28rpx;
  padding: 0 30rpx;
  border-radius: 30rpx;
  line-height: 2.2;
}
