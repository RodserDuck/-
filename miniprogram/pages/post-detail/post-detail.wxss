/* pages/post-detail/post-detail.wxss - 帖子详情页全新美化 */

/* 页面基础 */
page { background: #f0f6ff; }
.detail-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ===================== 主内容滚动 ===================== */
.main-scroll {
  flex: 1;
  min-height: 0;
}

/* ===================== 帖子区域 ===================== */
.post-section {
  background: #fff;
  margin: 24rpx 28rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 156, 246, 0.08);
}

/* 用户行 */
.user-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.user-avatar-wrap {
  margin-right: 20rpx;
}

.user-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 4rpx solid #e8f2ff;
  box-shadow: 0 4rpx 12rpx rgba(91, 156, 246, 0.15);
}

.user-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e3a5f;
}

.user-info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.user-college {
  font-size: 22rpx;
  color: #5b9cf6;
  background: #eff6ff;
  padding: 2rpx 12rpx;
  border-radius: 100rpx;
  font-weight: 500;
}

.user-time {
  font-size: 22rpx;
  color: #9ca3af;
}

.post-category-tag {
  background: linear-gradient(135deg, #5b9cf6, #74aef8);
  border-radius: 100rpx;
  padding: 8rpx 20rpx;
  flex-shrink: 0;
}

.category-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}

.post-title-wrap {
  margin-bottom: 20rpx;
}

.post-title-text {
  font-size: 38rpx;
  font-weight: 700;
  color: #1e3a5f;
  line-height: 1.45;
  display: block;
}

/* 帖子内容 */
.post-content {
  margin-bottom: 24rpx;
}

.content-text {
  font-size: 32rpx;
  color: #2d3748;
  line-height: 1.9;
  display: block;
}

/* 图片网格 */
.post-images {
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.image-wrap {
  display: inline-block;
  vertical-align: top;
  margin: 4rpx;
}

/* 单图：父级占满一行，避免 inline-block + 子 100% 宽度塌成 0 */
.image-wrap.single {
  display: block;
  width: 100%;
  margin: 8rpx 0;
}

.image-wrap .post-img {
  width: 210rpx;
  height: 210rpx;
  border-radius: 16rpx;
  display: block;
  background: #f3f4f6;
}

.image-wrap.single .post-img {
  width: 100%;
  height: auto;
  min-height: 200rpx;
  max-height: 720rpx;
  border-radius: 16rpx;
}

/* 互动数据栏 */
.post-stats {
  display: flex;
  gap: 40rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #f3f4f6;
  border-bottom: 1rpx solid #f3f4f6;
  margin-bottom: 20rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-icon { font-size: 28rpx; }

.stat-text {
  font-size: 24rpx;
  color: #9ca3af;
}

/* 点赞按钮 */
.like-btn-wrap {
  display: flex;
  justify-content: center;
}

.like-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #f8fafc;
  border-radius: 100rpx;
  padding: 16rpx 48rpx;
  border: 2rpx solid #e8f2ff;
  transition: all 0.2s;
}

.like-btn.liked {
  background: linear-gradient(135deg, #fef2f2, #fee2e2);
  border-color: #fecaca;
}

.like-icon { font-size: 36rpx; }

.like-text {
  font-size: 28rpx;
  color: #6b7280;
  font-weight: 500;
}

.like-btn.liked .like-text { color: #ef4444; }

/* ===================== 评论区 ===================== */
.comment-section {
  margin: 0 28rpx 0;
  padding-top: 8rpx;
}

.comment-section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 0 20rpx;
}

.section-title-bar {
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(180deg, #5b9cf6, #38bdf8);
  border-radius: 4rpx;
}

.section-title-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e3a5f;
}

/* 空状态 */
.comment-empty {
  background: #fff;
  border-radius: 20rpx;
  padding: 64rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(91, 156, 246, 0.06);
}

.empty-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 28rpx; color: #9ca3af; }

/* 评论列表 */
.comment-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* 单条评论 */
.comment-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(91, 156, 246, 0.06);
}

.comment-user-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  border: 3rpx solid #e8f2ff;
}

.comment-user-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.comment-nickname {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e3a5f;
}

.comment-time {
  font-size: 22rpx;
  color: #9ca3af;
}

.comment-body {
  margin-bottom: 12rpx;
  padding-left: 80rpx;
}

.comment-text {
  font-size: 30rpx;
  color: #374151;
  line-height: 1.7;
}

.comment-actions {
  padding-left: 80rpx;
  display: flex;
  align-items: center;
}

.reply-btn {
  font-size: 24rpx;
  color: #5b9cf6;
  font-weight: 500;
  padding: 6rpx 16rpx;
  background: #eff6ff;
  border-radius: 100rpx;
}

/* 子评论 */
.reply-list {
  margin-top: 16rpx;
  padding-left: 80rpx;
  border-left: 4rpx solid #e8f2ff;
  padding-left: 28rpx;
  margin-left: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.reply-item {
  padding: 0;
}

.reply-user-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.reply-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.reply-user-meta {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.reply-nickname {
  font-size: 26rpx;
  font-weight: 600;
  color: #5b9cf6;
}

.reply-time {
  font-size: 20rpx;
  color: #9ca3af;
}

.reply-body {
  padding-left: 60rpx;
  margin-bottom: 8rpx;
}

.reply-label {
  font-size: 26rpx;
  color: #5b9cf6;
  font-weight: 600;
  margin-right: 8rpx;
}

.reply-text {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.6;
}

/* 底部占位 */
.bottom-space { height: 32rpx; }

/* ===================== 底部评论输入栏 ===================== */
.comment-input-bar {
  background: #fff;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f3f4f6;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

/* 回复提示 */
.reply-tip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #eff6ff;
  border-radius: 12rpx;
  padding: 10rpx 16rpx;
  margin-bottom: 12rpx;
}

.reply-tip-text {
  font-size: 24rpx;
  color: #5b9cf6;
  font-weight: 500;
  flex: 1;
}

.reply-cancel {
  font-size: 36rpx;
  color: #9ca3af;
  padding: 0 8rpx;
  line-height: 1;
}

/* 输入行 */
.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.comment-input {
  flex: 1;
  background: #f8fafc;
  border-radius: 100rpx;
  padding: 18rpx 28rpx;
  font-size: 28rpx;
  color: #2d3748;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.comment-input:focus {
  border-color: #5b9cf6;
  background: #fff;
}

.send-btn {
  background: #e8f2ff;
  color: #9ca3af;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 100rpx;
  border: none;
  transition: all 0.2s;
}

.send-btn.active {
  background: linear-gradient(135deg, #5b9cf6, #38bdf8);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(91, 156, 246, 0.35);
}

.send-btn::after { border: none; }
